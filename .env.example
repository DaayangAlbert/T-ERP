# ===== Database =====
# PostgreSQL Neon.tech connection string
DATABASE_URL="postgresql://user:password@host:5432/terp?sslmode=require"

# ===== App =====
# Public app domain used by the multi-tenant subdomain middleware.
# Local dev: terp.local (with /etc/hosts mapping batimcam.terp.local 127.0.0.1)
NEXT_PUBLIC_APP_DOMAIN="terp.local"
NEXT_PUBLIC_APP_URL="http://localhost:5000"

# ===== Auth =====
# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-in-production"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ===== Email (Resend) =====
RESEND_API_KEY=""
RESEND_FROM="T-ERP <noreply@terpgroup.com>"

# ===== Optional storage (phase 2) =====
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
