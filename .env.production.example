# =============================================================================
#  T-ERP — Configuration PRODUCTION (terpgroup.com)
# =============================================================================
#
#  Sur le VPS OVH, ce fichier doit être copié en `.env.production` (jamais
#  commité) et rempli avec les vraies valeurs. Permissions strictes :
#
#    chown ubuntu:ubuntu .env.production
#    chmod 600 .env.production
#
# =============================================================================

# ----- Mode -----
NODE_ENV="production"
PORT="3000"
# IMPORTANT : Next utilise HOSTNAME pour binder l'interface. Sur le VPS,
# l'app écoute sur 127.0.0.1, et Nginx reverse-proxy via :443.
HOSTNAME="127.0.0.1"

# ----- Base de données PostgreSQL locale (sur le même VPS) -----
# Créer en local : voir docs/DEPLOYMENT.md étape 3
DATABASE_URL="postgresql://terp_app:CHANGE_ME_STRONG_DB_PWD@127.0.0.1:5432/terp_prod?schema=public"

# ----- Domaine multi-tenant -----
# Le middleware résout les sous-domaines : batimcam.terpgroup.com → tenant batimcam
NEXT_PUBLIC_APP_DOMAIN="terpgroup.com"
NEXT_PUBLIC_APP_URL="https://terpgroup.com"
NEXT_PUBLIC_BASE_URL="https://terpgroup.com"

# ----- Auth (JWT) -----
# OBLIGATOIRE : générer avec
#   openssl rand -base64 48
# Remplacer la valeur ci-dessous. Ne jamais réutiliser ce secret entre
# environnements. Rotation tous les 6 mois recommandée.
JWT_SECRET="REPLACE_WITH_openssl_rand_base64_48"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
ADMIN_JWT_TTL="30m"

# ----- Email transactionnel (Resend) -----
# Inscription gratuite : https://resend.com (3000 emails/mois sur le plan free)
# Vérifier le domaine terpgroup.com dans Resend avant d'envoyer.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM="T-ERP <noreply@terpgroup.com>"
RESEND_SALES_TO="sales@terpgroup.com"

# ----- Storage CV/documents (optionnel — Cloudflare R2 recommandé) -----
# Activer une fois que l'app sera stable en prod. Par défaut : stockage
# local public/uploads/ (suffisant < 10 Go).
# S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
# S3_BUCKET="terp-prod-documents"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_REGION="auto"
# S3_PUBLIC_URL="https://docs.terpgroup.com"

# ----- WhatsApp Business (Meta Cloud API — optionnel phase 2) -----
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_ACCESS_TOKEN=""
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ----- Sentry (monitoring erreurs — optionnel) -----
# SENTRY_DSN=""
# SENTRY_ORG="terp"
# SENTRY_PROJECT="terp-prod"

# ----- Backup automatique -----
# Cible : remote backup (S3 / OVH Object Storage). Voir scripts/backup.sh.
# BACKUP_S3_BUCKET=""
# BACKUP_S3_ENDPOINT=""
# BACKUP_RETENTION_DAYS="30"

# ----- Sécurité plateforme (Super-Admin Anthropic) -----
# IPs whitelistées pour /admin/* (CIDR séparés par virgule).
# Vide = tout autorisé (déconseillé en prod). Exemple : VPN équipe.
# ADMIN_IP_WHITELIST="89.0.0.0/24,10.0.0.0/8"
