# Backend API base URL.
# If omitted, the frontend falls back to /api/v1 and relies on the Vite proxy in development.
VITE_API_BASE_URL=http://localhost:5000

# Socket.IO server URL.
# If omitted, the frontend falls back to the API origin.
VITE_SOCKET_URL=http://localhost:5000

# Comma-separated modules enabled in the shell navigation.
# Start with the focused V1 scope by default.
VITE_ENABLED_BACKEND_MODULES=companies,users,projects,planning,attendance,finance,inventory,payroll,procurement,recruitment,chat,calls
