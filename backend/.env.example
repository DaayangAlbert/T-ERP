# Flask runtime
FLASK_ENV=development
DATABASE_URL=postgresql+psycopg://postgres:change-me@localhost:5432/terp_dev
JWT_SECRET_KEY=replace-with-a-long-random-secret

# Optional cross-origin settings for browser clients.
# In production, use explicit frontend origins or leave these empty when serving the frontend from the same origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SOCKETIO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Required only when running backend/seed_super_admin.py
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-this-admin-password
SUPER_ADMIN_FIRST_NAME=Platform
SUPER_ADMIN_LAST_NAME=Admin
SUPER_ADMIN_LANG=fr

# Optional demo company seed values for backend/scripts/seed_demo_company.py
