  journalCode String // "ACH", "VTE", "BQ", "OD", "PAIE", "CAI"
  entryDate   DateTime
  reference   String
  description String

  status CptEntryStatus @default(DRAFT)

  // Pièce jointe justificative (1 par écriture) — facture, reçu, photo, etc.
  // Stockée sous public/uploads/comptable/<tenantId>/<YYYY>/<MM>/<uuid><ext>
  attachmentUrl       String?
  attachmentName      String?
  attachmentMimeType  String?
  attachmentSizeBytes BigInt?

  createdById   String
  createdBy     User      @relation("EntryCreator", fields: [createdById], references: [id])
  validatedById String?
  validatedBy   User?     @relation("EntryValidator", fields: [validatedById], references: [id])
  validatedAt   DateTime?

  lines EntryLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, journalCode, reference])
  @@index([tenantId, journalCode, entryDate])
  @@index([siteId])
  @@map("cpt_entries")
}

