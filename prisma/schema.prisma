// T-ERP — Schéma Prisma MVP
// Base PostgreSQL · multi-tenant par champ tenantId (sera évolué en schémas séparés en phase 2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// MULTI-TENANT : table globale des tenants
// ========================================

model Tenant {
  id                 String            @id @default(cuid())
  slug               String            @unique // batimcam, njoya, socabtp...
  subdomain          String? // batimcam.terp.cm
  name               String
  taxId              String? // N° contribuable / NIU
  cnpsId             String? // N° employeur CNPS
  country            String            @default("CM")
  legalForm          LegalForm? // forme juridique
  plan               Plan              @default(STARTER)
  subscriptionPlanId String? // SubscriptionPlan T-ERP (Super-Admin Bloc 0)
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id])
  status             TenantStatus      @default(ACTIVE)
  logoUrl            String?
  primaryColor       String?           @default("#A855F7")
  secondaryColor     String?

  // Coordonnées entreprise (affichées sur les documents officiels — bulletins,
  // factures, attestations). Distinctes de l'adresse de facturation T-ERP.
  contactAddress    String?
  contactPhone      String?
  contactEmail      String?
  websiteUrl        String?
  // Signature DRH scannée + cachet entreprise scanné (URLs vers assets stockés).
  // Utilisés sur les bulletins officiels comme preuve d'authentification.
  signatureImageUrl String?
  stampImageUrl     String?
  drhSignatoryName  String? // nom imprimé sous la signature (ex: "Mme Marie ETOUNDI")

  // Pointage de présence — coordonnées GPS du bureau (siège/direction).
  // Les employés de la direction (sans chantier affecté) pointent ici ;
  // configuré par l'informaticien. officeRadiusM = rayon de tolérance (m).
  officeLat     Float?
  officeLng     Float?
  officeRadiusM Int?

  // Limites plan (override Enterprise)
  maxUsers     Int? @default(50)
  maxSites     Int? @default(10)
  maxStorageGb Int? @default(20)

  // Cycle de vie SaaS (Super-Admin Bloc 0)
  provisionedAt      DateTime?
  suspendedAt        DateTime?
  suspensionReason   String?
  terminatedAt       DateTime?
  dataRetentionEndAt DateTime?
  isDemoTenant       Boolean   @default(false)
  demoExpiresAt      DateTime?

  // Contact facturation
  billingContactEmail String?
  billingContactName  String?
  billingAddress      String?
  paymentMethod       PaymentMethod?

  // Hiérarchie de groupe (Phase 2 / fn 1.2)
  isGroup  Boolean  @default(false)
  parentId String?
  parent   Tenant?  @relation("TenantGroup", fields: [parentId], references: [id])
  children Tenant[] @relation("TenantGroup")
  sector   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                     User[]
  sites                     Site[]
  operationalPlans          OperationalPlan[]
  jobOffers                 JobOffer[]
  payslips                  Payslip[]
  conversations             Conversation[]
  documents                 Document[]
  auditLogs                 AuditLog[]
  objectives                Objective[]
  cashFlowProjections       CashFlowProjection[]
  boardReports              BoardReport[]
  validations               Validation[]
  delegations               Delegation[]
  reports                   Report[]
  settings                  TenantSettings?
  milestones                Milestone[]
  resourceConflicts         ResourceConflict[]
  successionPlans           SuccessionPlan[]
  trainings                 Training[]
  socialIndicators          SocialIndicator[]
  financialPeriods          FinancialPeriod[]
  financialCommitments      FinancialCommitment[]
  bankAccounts              BankAccount[]
  projectAccounts           ProjectAccount[]
  salaryAccount             SalaryAccount?
  overheadRuns              OverheadRun[]
  accountingPeriods         AccountingPeriod[]
  accountingEntries         AccountingEntry[]
  annualClosures            AnnualClosure[]
  suppliers                 Supplier[]
  frameworkContracts        FrameworkContract[]
  purchaseOrders            PurchaseOrder[]
  fixedAssets               FixedAsset[]
  stockMovements            StockMovement[]
  inventories               Inventory[]
  losses                    Loss[]
  // DT — Espace Direction Technique
  dtAlerts                  DtAlert[]
  tenders                   Tender[]
  competitors               Competitor[]
  operatingMethods          OperatingMethod[]
  templatePlannings         TemplatePlanning[]
  referenceRatios           ReferenceRatio[]
  crews                     Crew[]
  certifications            Certification[]
  // LOG — Logisticien siège
  equipment                 Equipment[]
  interSiteTransfers        InterSiteTransfer[]
  // GED — Référent documentaire (Bloc 0)
  documentSpaces            DocumentSpace[]
  documentClassifications   DocumentClassification[]
  documentWorkflowTemplates DocumentWorkflowTemplate[]
  gedAuditEvents            GedAuditEvent[]
  // Super-Admin Bloc 0 — plateforme SaaS
  subscriptions             Subscription[]
  saasInvoices              SaasInvoice[]
  platformIncidents         PlatformIncident[]
  globalAuditLogs           GlobalAuditLog[]
  tenantFeatureFlags        TenantFeatureFlag[]
  profileChangeRequests     ProfileChangeRequest[]
  // SG — Secrétaire Général (Bloc 0)
  clientContracts           ClientContract[]
  governanceMeetings        GovernanceMeeting[]
  boardMembers              BoardMember[]
  shareholders              Shareholder[]
  legalCases                LegalCase[]
  regulatoryRegisters       RegulatoryRegister[]
  officialCorrespondences   OfficialCorrespondence[]
  institutions              Institution[]
  professionalApprovals     ProfessionalApproval[]
  // OUV — Espace Ouvrier (Bloc 0)
  salaryAdvanceRequests     SalaryAdvanceRequest[]
  missionAssignments        MissionAssignment[]
  hseIncidentReports        HseIncidentReport[]
  epiAssignments            EpiAssignment[]
  // OUV — Attestations RH (fn 1.4)
  attestationRequests       AttestationRequest[]
  // OUV — Prêts outils (fn 1.8)
  toolLoans                 ToolLoan[]
  // DAF — Circuits de paiement
  paymentCircuitTemplates   PaymentCircuitTemplate[]
  TrainingSession           TrainingSession[]

  @@index([parentId])
  @@map("tenants")
}

enum Plan {
  STARTER
  STANDARD
  BUSINESS
  ENTERPRISE
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  TRIAL
  DEMO
  SUSPENDED
  ARCHIVED
  TERMINATED
  PURGED
}

enum LegalForm {
  SA
  SARL
  SAS
  GIE
  INDIVIDUAL
  OTHER
}

enum PaymentMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  CARD
  INVOICE_30D
}

// ========================================
// UTILISATEURS ET RÔLES
// ========================================

model User {
  id       String  @id @default(cuid())
  // Multi-tenant : tenantId obligatoire pour tout employé.
  // null UNIQUEMENT pour role CANDIDATE (chercheur d'emploi externe) ou SUPER_ADMIN
  // (admin SaaS transverse). Garanti par la CHECK constraint
  // `users_tenant_required_for_employees` (migration 20260513020000).
  // Validation côté API : src/schemas/user.ts → userCreationSchema.
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String  @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?

  // Si employé du tenant
  employeeId           String?       @unique // ex: EMP-2018-00001
  matricule            String?       @unique // matricule employeur BatimCAM (ex: BTC-2018-0142)
  hireDate             DateTime?
  position             String? // intitulé du poste
  category             String? // catégorie pro (Cadre HC, ETAM, OQ, OS...)
  professionalCategory String? // grille BTP (ex: "Catégorie 8 · échelon 3")
  // Décomposition fine de la grille salariale (affichée sur le bulletin officiel).
  // `professionalCategory` reste l'étiquette résumée ; les champs ci-dessous
  // permettent un affichage tabulaire structuré (ex: Échelon "E3", Classe "2",
  // Indice 450, Coefficient 1.45).
  echelon              String? // ex: "E3"
  classCategory        String? // ex: "Classe 2"
  indiceSalarial       Int? // ex: 450
  coefficientSalarial  Float? // ex: 1.45
  // Salaire de base contractuel mensuel (FCFA). Si null → fallback barème
  // catégorie (cf. payroll-rates.ts). Modification via RH crée une row
  // SalaryHistory pour la traçabilité.
  baseSalary           BigInt?
  salaryGrade          String? // libellé libre, ex: "Grille A - Position III"
  department           String? // ex: "Études & Méthodes" (libellé libre, distinct de Site)
  cnpsNumber           String?
  cnpsCardNumber       String? // N° de carte CNPS (ex: 9876543210)
  contractType         ContractType?

  // EMP — identité personnelle (Bloc 0 Employé / fn 1.5)
  dateOfBirth           DateTime?
  cniNumber             String?
  phoneMobile           String?
  personalEmail         String?
  address               String?
  familyStatus          String? // "Marié · 3 enfants"
  emergencyContactName  String?
  emergencyContactPhone String?

  // EMP — informations professionnelles complémentaires
  niu        String? // NIU DGI (F218014203187)
  bankName   String? // ex: "Afriland First Bank"
  bankAgency String?
  rib        String?
  teamLeader Boolean @default(false) // chef d'équipe → consulte son équipe

  // EMP — préférences notification & langue
  preferredLanguage   String @default("fr-CM") // "fr-CM" ou "en-CM"
  notificationChannel String @default("WHATSAPP") // "WHATSAPP" | "EMAIL" | "PUSH"

  // OUV — auth téléphone + PIN 6 chiffres (Bloc 0 Ouvrier)
  // Les ouvriers n'ont pas d'email pro : login via phone + PIN. L'email reste
  // requis (unique) mais peut être synthétique : worker-{matricule}@<slug>.local.
  pinHash             String? // bcrypt du PIN 6 chiffres
  phoneVerified       Boolean   @default(false)
  pinFailedAttempts   Int       @default(0) // compteur brute-force
  pinLockedUntil      DateTime? // blocage 1h si > 5 essais
  isGuard             Boolean   @default(false) // gardien (widget tour de garde)
  workerQualification String? // libellé court qualif (ex: "Maçon-coffreur niveau B")
  deviceFingerprints  String[]  @default([]) // IDs appareils enrôlés (max 3)

  // Sécurité
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  emailVerified    Boolean   @default(false)
  lastLoginAt      DateTime?

  // IT — pouvoirs spéciaux (octroyés par DG uniquement, jamais par IT_ADMIN lui-même)
  canManageUsers          Boolean @default(false)
  canManageRoles          Boolean @default(false)
  canManageTenantSettings Boolean @default(false)
  canManageIntegrations   Boolean @default(false)
  canViewTechnicalLogs    Boolean @default(false)

  // GED — accès transverse documentaire (ARCHIVIST uniquement)
  canReadAllDocuments Boolean @default(false)

  // SG — pouvoirs spéciaux Secrétaire Général (octroyés par DG)
  canManageCorporateGovernance    Boolean @default(false) // CA, AG, registres
  canManageMarketContracts        Boolean @default(false) // marchés clients, avenants, garanties
  canManageLegalCases             Boolean @default(false) // contentieux, dossiers avocats
  canManageOfficialCorrespondence Boolean @default(false) // courriers signés DG
  canReadAllDashboards            Boolean @default(false) // lecture seule autres directions

  // Candidat — Profil & recherche (CAND fn 1.2)
  cvUrl                String?
  desiredJob           String? // poste recherché (ex. "Conducteur de Travaux")
  desiredContractType  ContractType?
  desiredLocation      String?
  desiredSalaryMin     BigInt? // FCFA
  desiredSalaryMax     BigInt? // FCFA
  availability         String? // ex. "Immédiate", "Sous 1 mois"
  mobilityDailyTravel  Boolean       @default(false)
  mobilityMissions     Boolean       @default(false)
  mobilityExpatriation Boolean       @default(false)
  candidateSkills      String[]      @default([]) // chips
  candidateLanguages   Json? // [{ name: "Français", level: "natif" }, ...]
  gdprConsent          Boolean       @default(false)
  gdprConsentAt        DateTime?

  // Rôle principal (MVP — rôles avancés en phase 2)
  role Role @default(EMPLOYEE)

  // Périmètre de chantiers (Comptable Bloc 0). Vide = vue Direction (accès tous chantiers
  // pour ACCOUNTANT) ; peuplé = restriction au sous-ensemble.
  assignedSiteIds String[] @default([])

  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  payslips                       Payslip[]
  payrollEmployeeSnapshots       PayrollEmployeeSnapshot[]
  applications                   Application[]
  sentMessages                   Message[]                     @relation("SentMessages")
  conversationParticipants       ConversationParticipant[]
  notifications                  Notification[]
  auditLogs                      AuditLog[]
  managedSites                   Site[]                        @relation("SiteManager")
  authoredOperationalPlans       OperationalPlan[]             @relation("AuthoredOperationalPlans")
  materialRequestsCreated        MaterialRequest[]             @relation("MaterialRequester")
  materialRequestsFulfilled      MaterialRequest[]             @relation("MaterialFulfiller")
  progressReportsAuthored        SiteProgressReport[]          @relation("ProgressReportAuthor")
  progressReportsValidated       SiteProgressReport[]          @relation("ProgressReportValidator")
  ccPlanningTeamsLed             CcPlanningTeam[]              @relation("CcPlanningTeamLeader")
  ccPlanningTeamMemberships      CcPlanningTeamMember[]
  ccPlanningTasksCreated         CcPlanningTask[]              @relation("CcPlanningTaskCreator")
  cdtWeeklyReportsAuthored       CdtWeeklyReport[]             @relation("CdtWeeklyReportAuthor")
  cdtWeeklyReportsValidated      CdtWeeklyReport[]             @relation("CdtWeeklyReportValidator")
  dtMonthlyReportsAuthored       DtMonthlyTechReport[]         @relation("DtMonthlyTechReportAuthor")
  dtMonthlyReportsValidated      DtMonthlyTechReport[]         @relation("DtMonthlyTechReportValidator")
  dtravMonthlyReportsAuthored    DtravMonthlyReport[]          @relation("DtravMonthlyReportAuthor")
  dtravMonthlyReportsValidated   DtravMonthlyReport[]          @relation("DtravMonthlyReportValidator")
  qhseMonthlyReportsAuthored     QhseMonthlyReport[]           @relation("QhseMonthlyReportAuthor")
  qhseMonthlyReportsValidated    QhseMonthlyReport[]           @relation("QhseMonthlyReportValidator")
  dafMonthlyReportsAuthored      DafMonthlyFinancialReport[]   @relation("DafMonthlyFinancialReportAuthor")
  dafMonthlyReportsValidated     DafMonthlyFinancialReport[]   @relation("DafMonthlyFinancialReportValidator")
  dgSettings                     DgSettings?
  objectives                     Objective[]
  boardReports                   BoardReport[]
  validationsInitiated           Validation[]                  @relation("ValidationInitiator")
  validationsAssigned            Validation[]                  @relation("ValidationCurrentApprover")
  validationsDecided             Validation[]                  @relation("ValidationDecidedBy")
  delegationsGiven               Delegation[]                  @relation("DelegationFrom")
  delegationsReceived            Delegation[]                  @relation("DelegationTo")
  reports                        Report[]
  sessions                       Session[]
  trainings                      Training[]
  successionsAsIncumbent         SuccessionPlan[]              @relation("SuccessionIncumbent")
  successionsAsSuccessor         SuccessionPlan[]              @relation("SuccessionSuccessor")
  preferences                    UserPreferences?
  signature                      UserSignature?
  agendaEvents                   AgendaEvent[]
  interestDeclarations           InterestDeclaration[]
  benefits                       BenefitInKind[]
  performanceBonuses             PerformanceBonus[]
  dafSettings                    DafSettings?
  signaturePower                 UserSignaturePower?
  rhSettings                     RhSettings?
  employeeProfile                EmployeeProfile?
  employeeDocuments              EmployeeDocument[]
  // Bloc 0 Comptable — workflow promotion + écritures + factures
  promotionRequestsAsTarget      RolePromotionRequest[]        @relation("PromotionTarget")
  promotionRequestsAsRequester   RolePromotionRequest[]        @relation("PromotionRequester")
  cptEntriesCreated              Entry[]                       @relation("EntryCreator")
  cptEntriesValidated            Entry[]                       @relation("EntryValidator")
  cashboxMovements               CashboxMovement[]
  // DTrav — relations chantier
  dailyReportsSubmitted          SiteDailyReport[]             @relation("DailyReportAuthor")
  dailyReportsValidated          SiteDailyReport[]             @relation("DailyReportValidator")
  workforceMemberships           SiteWorkforceMember[]
  amendmentsInitiated            ContractAmendment[]           @relation("AmendmentInitiator")
  documentsUploaded              SiteDocument[]                @relation("DocumentUploader")
  moaReportsAuthored             MoaReport[]                   @relation("MoaReportAuthor")
  // CC — relations
  attendancesAsWorker            Attendance[]                  @relation("AttendanceWorker")
  attendancesRecorded            Attendance[]                  @relation("AttendanceRecorder")
  attendanceSessionsCompleted    AttendanceSessionCompletion[]
  deliveryReceiptsRecorded       DeliveryReceipt[]
  safetyTalksCompleted           HseSafetyTalk[]
  // MAG — relations magasin
  warehousesKept                 Warehouse[]                   @relation("WarehouseKeeper")
  warehouseMovementsRecorded     WarehouseMovement[]           @relation("WarehouseMovementRecorder")
  warehouseInventoriesCompleted  WarehouseInventory[]
  // IT — relations administration tenant
  apiKeysCreated                 ApiKey[]                      @relation("ApiKeyCreator")
  apiKeysRevoked                 ApiKey[]                      @relation("ApiKeyRevoker")
  technicalLogs                  TechnicalLog[]
  // Candidat — matching offres recommandées
  candidateMatches               JobMatch[]                    @relation("CandidateMatches")
  candidateExperiences           CandidateExperience[]
  candidateFormations            CandidateFormation[]
  // DT — Espace Direction Technique (Bloc 0+)
  dtSettings                     DtSettings?
  managedTenders                 Tender[]                      @relation("TenderStudyOwner")
  dtIncidentReports              HseIncident[]                 @relation("IncidentReporter")
  dtAuditsLed                    SiteAudit[]                   @relation("AuditAuditor")
  dtNcOwned                      NonConformity[]               @relation("NcOwner")
  dtSubcontractorEvals           SubcontractorEvaluation[]     @relation("SubEvaluator")
  dtCrewsLed                     Crew[]                        @relation("CrewLeader")
  dtMethodsAuthored              OperatingMethod[]             @relation("MethodAuthor")
  dtTemplatePlannings            TemplatePlanning[]            @relation("TemplatePlanningAuthor")
  dtRexAuthored                  SiteRex[]                     @relation("RexAuthor")
  // LOG — Logisticien siège
  logTransfersArbitrated         InterSiteTransfer[]           @relation("TransferArbitrator")
  logEquipmentAssignments        EquipmentAssignment[]         @relation("EquipmentDriver")
  // EMP — relations employé/ouvrier (Bloc 0 EMP)
  timeReportsOwned               TimeReport[]                  @relation("TimeReportOwner")
  timeReportsPointed             TimeReport[]                  @relation("TimeReportPointer")
  timeReportsResolved            TimeReport[]                  @relation("TimeReportResolver")
  leaveRequestsOwned             LeaveRequest[]                @relation("LeaveRequestOwner")
  leaveRequestsValidated         LeaveRequest[]                @relation("LeaveRequestValidator")
  leaveBalanceOwned              LeaveBalance?                 @relation("LeaveBalanceOwner")
  // GED — Référent documentaire (Bloc 0)
  gedSpacesResponsible           DocumentSpace[]               @relation("SpaceResponsible")
  gedWorkflowsInitiated          DocumentWorkflowInstance[]    @relation("WorkflowInitiator")
  gedWorkflowsAssigned           DocumentWorkflowStep[]        @relation("WorkflowStepAssignee")
  gedAccessRequestsMade          DocumentAccessRequest[]       @relation("AccessRequester")
  gedAccessRequestsDecided       DocumentAccessRequest[]       @relation("AccessDecider")
  gedAuditEvents                 GedAuditEvent[]               @relation("GedAuditActor")
  // EMP — Demandes de modification de profil
  profileChangeRequests          ProfileChangeRequest[]        @relation("ChangeRequestUser")
  profileChangesReviewed         ProfileChangeRequest[]        @relation("ChangeRequestReviewer")
  // SG — Secrétaire Général (Bloc 0)
  sgBoardMemberships             BoardMember[]
  sgRegulatoryRegisters          RegulatoryRegister[]          @relation("RegisterResponsible")
  sgCorrespondencesAssigned      OfficialCorrespondence[]      @relation("CorrespondenceAssignee")
  // OUV — Espace Ouvrier (Bloc 0 Ouvrier)
  salaryAdvancesRequested        SalaryAdvanceRequest[]        @relation("SalaryAdvanceRequester")
  salaryAdvancesValidated        SalaryAdvanceRequest[]        @relation("SalaryAdvanceValidator")
  missionsAssigned               MissionAssignment[]           @relation("MissionWorker")
  missionsCreated                MissionAssignment[]           @relation("MissionAssigner")
  hseReportsCreated              HseIncidentReport[]           @relation("HseReporter")
  hseReportsAssigned             HseIncidentReport[]           @relation("HseAssignee")
  epiAssignments                 EpiAssignment[]               @relation("EpiOwner")
  // OUV — Attestations RH (Bloc 1 fn 1.4)
  attestationsRequested          AttestationRequest[]          @relation("AttestationRequester")
  attestationsPrepared           AttestationRequest[]          @relation("AttestationPreparer")
  // OUV — Prêts outils (Bloc 1 fn 1.8)
  toolLoansBorrowed              ToolLoan[]                    @relation("ToolLoanBorrower")
  toolLoansIssued                ToolLoan[]                    @relation("ToolLoanIssuer")
  // DAF — Circuits de paiement (workflow administratif client)
  paymentCircuitTemplatesCreated PaymentCircuitTemplate[]
  paymentTracksAssigned          PaymentTrack[]                @relation("PaymentTrackAssignee")
  paymentTracksCreated           PaymentTrack[]                @relation("PaymentTrackCreator")
  paymentTrackStepsValidated     PaymentTrackStep[]            @relation("PaymentTrackStepValidator")
  paymentTrackStepsBlocked       PaymentTrackStep[]            @relation("PaymentTrackStepBlocker")
  paymentTrackStepDocsProvided   PaymentTrackStepDocument[]
  SalaryHistory                  SalaryHistory[]
  employmentContracts            EmploymentContract[]          @relation("EmploymentContractEmployee")
  employmentContractsDrafted     EmploymentContract[]          @relation("EmploymentContractDrafter")
  employmentContractsSigned      EmploymentContract[]          @relation("EmploymentContractEmployerSigner")
  // CPT analytique — comptes projet / compte salaire / répartition charges siège
  projectAccountMovements        ProjectAccountMovement[]
  salaryAccountMovements         SalaryAccountMovement[]
  overheadRunsExecuted           OverheadRun[]                 @relation("OverheadRunExecutor")

  @@index([tenantId, email])
  @@index([tenantId, role])
  @@index([tenantId, phone])
  @@map("users")
}

// ========================================
// OBJECTIFS DG (Phase 2 / fn 1.3)
// ========================================
// Objectifs annuels / trimestriels suivis par le DG.
model Objective {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId  String
  owner    User   @relation(fields: [ownerId], references: [id])

  category    ObjectiveCategory
  title       String
  description String?           @db.Text

  targetValue Float
  actualValue Float  @default(0)
  unit        String // "FCFA", "%", "jours", "unités", "M FCFA", etc.

  period  ObjectivePeriod
  year    Int
  quarter Int? // 1..4 si period = QUARTERLY ou MONTHLY ; null si ANNUAL
  weight  Int             @default(1) // pondération sur la note globale

  status    ObjectiveStatus @default(IN_PROGRESS)
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, year, period])
  @@index([ownerId, year])
  @@map("objectives")
}

enum ObjectiveCategory {
  FINANCIAL
  COMMERCIAL
  HR
  HSE
  STRATEGIC
}

enum ObjectivePeriod {
  ANNUAL
  QUARTERLY
  MONTHLY
}

enum ObjectiveStatus {
  IN_PROGRESS
  AT_RISK
  ACHIEVED
  MISSED
  CANCELLED
}

// ========================================
// REPORTING CONSEIL D'ADMINISTRATION (Phase 2 / fn 1.5)
// ========================================
// Rapports CA générés par le DG (mensuel, trimestriel, annuel,
// extraordinaire). Le contenu (KPIs agrégés, chantiers, RH…) est
// matérialisé au moment de la génération via lib/board-report-generator.
model BoardReport {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  type      BoardReportType
  period    String // "2026-04", "2026-T1", "2026"
  boardDate DateTime

  chapters Json // { financial: true, operational: true, ... }
  comments Json // { financial: "...", operational: "...", ... }
  data     Json // snapshot des KPIs au moment de la génération

  pdfUrl String?
  status BoardReportStatus @default(DRAFT)
  sentTo Json? // [{ email, name, sentAt }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, type, period])
  @@index([tenantId, status])
  @@map("board_reports")
}

enum BoardReportType {
  MONTHLY
  QUARTERLY
  ANNUAL
  EXTRAORDINARY
}

enum BoardReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
}

// ========================================
// TRÉSORERIE PRÉVISIONNELLE DG (Phase 2 / fn 1.4)
// ========================================
// Projections de flux de trésorerie sur les semaines à venir, alimentées
// soit automatiquement (factures, BC, paie, fiscalité) soit manuellement.
model CashFlowProjection {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         CashFlowType
  category     String // CLIENT_PAYMENT, SUPPLIER, SALARY, TAX_VAT, TAX_CNPS, TAX_IRPP, OTHER
  label        String
  amount       BigInt // toujours positif ; le signe est porté par `type`
  expectedDate DateTime
  probability  Int          @default(100) // 0..100, pondération de la prévision

  sourceType String? // INVOICE | PURCHASE_ORDER | PAYROLL | TAX | MANUAL
  sourceId   String?

  realized       Boolean   @default(false)
  realizedDate   DateTime?
  realizedAmount BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, expectedDate])
  @@index([tenantId, type, expectedDate])
  @@map("cashflow_projections")
}

enum CashFlowType {
  INCOME
  EXPENSE
}

// ========================================
// PRÉFÉRENCES DG (Phase 2 — Bloc 1)
// ========================================
// Stocke les préférences de l'espace DG (1 ligne par utilisateur DG).
// Les champs métier seront ajoutés au fil des fonctions livrées.
model DgSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dg_settings")
}

enum Role {
  // Gouvernance / actionnariat
  OWNER // Propriétaire / PCA — contrôle de gouvernance : voit tout, valide le critique

  // Direction
  DG // Directeur Général
  DAF // Directeur Administratif et Financier
  SECRETARY_GENERAL // Secrétaire Général (juriste · gouvernance/corporate/juridique)
  HR // Responsable RH

  // Production
  TECH_DIRECTOR // Directeur technique
  WORKS_DIRECTOR // Directeur de travaux (projet)
  WORKS_MANAGER // Conducteur de travaux
  SITE_MANAGER // Chef de chantier
  WORKER // Ouvrier
  QHSE_MANAGER // Responsable QHSE (Qualité, Hygiène, Sécurité, Environnement)

  // Support
  ACCOUNTANT
  PURCHASING_OFFICER // Chargé des achats / Responsable approvisionnements
  LOGISTICS
  WAREHOUSE // Magasinier
  ARCHIVIST // Documentaliste-Archiviste (Référent documentaire transverse, canReadAllDocuments)
  EMPLOYEE // Employé bureau

  // Externe
  CANDIDATE // Candidat portail emploi

  // Admin
  TENANT_ADMIN // Informaticien d'entreprise
  SUPER_ADMIN // Anthropic-style super-admin SaaS
}

enum ContractType {
  CDI
  CDD
  STAGE
  JOURNALIER
  PRESTATAIRE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ========================================
// CHANTIERS
// ========================================

model Site {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code   String // CHT-2025-031
  name   String // Pont Mfoundi
  client String // Commune Yaoundé I
  type   SiteType
  region String? // Yaoundé, Douala, Bafoussam...

  budget         BigInt // FCFA
  startDate      DateTime
  plannedEndDate DateTime
  actualEndDate  DateTime?

  progress Int        @default(0) // 0-100
  margin   Float      @default(0) // pourcentage
  status   SiteStatus @default(PLANNED)

  managerId String? // directeur de travaux
  manager   User?   @relation("SiteManager", fields: [managerId], references: [id])

  // Géoloc pour la vue carte (Phase 2 / Bloc 3 — fn 3.1)
  lat Float?
  lng Float?
  // Pointage de présence — rayon de tolérance (m) autour de lat/lng pour ce
  // chantier. Null = rayon par défaut. Configuré par l'informaticien.
  attendanceRadiusM Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DT — fn 1.1 : suivi technique avancé (déviation coût, avancement physique vs financier)
  actualSpentAmount BigInt            @default(0)
  deviationPercent  Float             @default(0)
  physicalProgress  Float             @default(0)
  financialProgress Float             @default(0)
  marginTarget      Float             @default(20)
  // DT — fn 1.2 : qualification MOA + contrat
  moaName           String?
  moaTypeKind       MoaType?
  contractTypeKind  ContractTypeSite?

  // Financement du marché (saisie du montant à la création)
  financingType  FinancingType @default(SINGLE)
  financings     Json          @default("[]") // [{ label, amountHT }] — montant HT par source de financement
  vatRate        Float         @default(19.25) // TVA %
  irRate         Float         @default(0) // IR / acompte %
  durationMonths Int? // délai d'exécution en mois (plannedEndDate = startDate + durationMonths)

  contract                 SiteContract?
  photos                   SitePhoto[]
  alerts                   SiteAlert[]
  decisions                SiteDecision[]
  // Bloc 0 Comptable — relations comptables analytiques + caisse chantier
  entries                  Entry[]                       @relation("EntrySite")
  entryLines               EntryLine[]                   @relation("EntryLineSite")
  supplierInvoices         SupplierInvoice[]             @relation("InvoiceSite")
  progressBillings         ProgressBilling[]             @relation("BillingSite")
  cashbox                  SiteCashbox?
  projectAccount           ProjectAccount?
  // DT — relations
  rex                      SiteRex[]
  hseIncidents             HseIncident[]
  audits                   SiteAudit[]
  ncs                      NonConformity[]
  subcontractorEvaluations SubcontractorEvaluation[]
  crewAssignments          CrewAssignment[]
  // LOG — relations
  equipmentAssignments     EquipmentAssignment[]
  transfersFrom            InterSiteTransfer[]           @relation("TransferFromSite")
  transfersTo              InterSiteTransfer[]           @relation("TransferToSite")
  // DTrav — relations chantier (Bloc 0 + Bloc 1)
  dailyReports             SiteDailyReport[]
  workforceMembers         SiteWorkforceMember[]
  teams                    SiteTeam[]
  planning                 SitePlanning?
  operationalPlans         OperationalPlan[]
  amendments               ContractAmendment[]
  penalties                SitePenalty[]
  stockAlerts              SiteStockAlert[]
  deliveries               Delivery[]
  documents                SiteDocument[]
  moaReports               MoaReport[]
  // CC — relations chantier
  attendances              Attendance[]
  attendanceCompletions    AttendanceSessionCompletion[]
  hseSafetyTalks           HseSafetyTalk[]
  // OUV — relations chantier (Bloc 0 Ouvrier)
  ouvMissionAssignments    MissionAssignment[]
  ouvHseReports            HseIncidentReport[]
  // MAG — relation magasin (1:1)
  warehouse                Warehouse?
  materialRequests         MaterialRequest[]
  progressReports          SiteProgressReport[]
  ccPlanningTeams          CcPlanningTeam[]
  ccPlanningTasks          CcPlanningTask[]
  cdtWeeklyReportSites     CdtWeeklyReportSite[]
  dtMonthlyReportSites     DtMonthlyTechReportSite[]
  // CDT — relations conducteur de travaux
  dailyPlans               DailyPlan[]
  qualityControls          QualityControl[]
  externalVisits           ExternalVisit[]
  cdtMilestones            CdtMilestone[]
  // GED — espace documentaire chantier (Bloc 0)
  documentSpaces           DocumentSpace[]
  // SG — marché client lié au chantier (Bloc 0)
  clientContracts          ClientContract[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("sites")
}

// DT — fn 1.2 : type de maître d'ouvrage et nature du contrat
enum MoaType {
  PUBLIC
  PRIVATE
  PARAPUBLIC
  INTERNATIONAL
}

enum ContractTypeSite {
  FIRM_PRICE
  UNIT_PRICE
  COST_PLUS
  DESIGN_BUILD
}

// Nature du financement du marché : unique ou conjoint (cofinancement).
enum FinancingType {
  SINGLE // financement simple
  JOINT // financement conjoint (plusieurs bailleurs/sources)
}

enum SiteType {
  ROAD // BTP routier
  BUILDING // Bâtiment
  CIVIL_ENG // Génie civil
  DEVELOPMENT // Aménagement
  HYDRAULIC // Forage / AEP
}

enum SiteStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  AT_RISK // Vigilance
  DRIFTING // Dérive
  COMPLETED
  ARCHIVED
}

// ========================================
// PAIE
// ========================================

model Payslip {
  id             String                   @id @default(cuid())
  tenantId       String
  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User                     @relation(fields: [userId], references: [id])
  payrollCycleId String?
  payrollCycle   PayrollCycle?            @relation(fields: [payrollCycleId], references: [id])
  snapshotId     String?
  snapshot       PayrollEmployeeSnapshot? @relation(fields: [snapshotId], references: [id])

  period      DateTime // 1er du mois (ex: 2025-09-01)
  periodLabel String? // "2026-04" — pratique pour affichage et tri lexico
  periodEnd   DateTime? // dernier jour de la période
  paymentDate DateTime
  paymentMode String    @default("VIREMENT") // VIREMENT, ESPECES, CHEQUE, MOMO

  // Totaux pré-calculés (calcul détaillé en phase 2)
  grossAmount     BigInt // Brut
  taxableGross    BigInt // Brut imposable
  netAmount       BigInt // Net à payer
  socialCharges   BigInt @default(0)
  fiscalCharges   BigInt @default(0)
  employerCharges BigInt @default(0)

  // EMP Bloc 0 — composantes détaillées du brut
  baseSalary         BigInt? // salaire de base (ex: 170 000 FCFA)
  overtimeAmount     BigInt  @default(0)
  overtimeHours      Float   @default(0)
  overtimeHours125   Float   @default(0) // heures sup soir 18h-22h
  overtimeHours150   Float   @default(0) // heures sup nuit 22h-6h
  overtimeHours200   Float   @default(0) // heures sup dimanche/férié
  seniorityBonus     BigInt  @default(0) // prime d'ancienneté
  transportAllowance BigInt  @default(0) // indemnité transport
  otherBonuses       Json? // autres primes [{ label, amount }]

  // EMP Bloc 0 — cotisations détaillées
  cnpsAmount      BigInt @default(0) // CNPS salarié
  irppAmount      BigInt @default(0) // Impôt sur le revenu
  otherDeductions BigInt @default(0)

  // EMP Bloc 0 — paiement effectif
  paymentMethod      PayslipPaymentMethod @default(BANK_TRANSFER)
  paymentBankAccount String? // ex: "Afriland First Bank · ****1842"
  paymentReference   String? // ex: "BS-2026-04-NDF"

  // EMP Bloc 0 — temps de travail synthèse
  workedDays    Int   @default(0)
  reportedHours Float @default(0)

  status PayslipStatus @default(DRAFT)

  // Workflow validation
  validatedN1At DateTime?
  validatedN2At DateTime?
  validatedN3At DateTime?
  paidAt        DateTime?

  pdfUrl String?

  // Numéro officiel du bulletin (ex: "BP-2026-04-000123"). Généré à la
  // validation N3 par séquence tenant/année. Affiché en en-tête du bulletin.
  bulletinNumber String? @unique
  // Adresse IP du serveur ayant généré le PDF — affichée dans la section
  // "Authentification" du bulletin pour traçabilité.
  generatedIp    String?

  verificationUuid  String?   @unique
  verificationCode  String?
  verificationHash  String?
  verifiedPublicUrl String?
  issuedAt          DateTime?
  cancelledAt       DateTime?
  replacedById      String?

  lines     PayslipLine[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([tenantId, userId, period])
  @@index([tenantId, period])
  @@index([userId, period])
  @@index([payrollCycleId])
  @@index([verificationUuid])
  @@map("payslips")
}

enum PayslipPaymentMethod {
  BANK_TRANSFER // virement
  MOBILE_MONEY // MOMO / Orange Money
  CASH // espèces
  CHECK // chèque
}

enum PayslipStatus {
  DRAFT
  CALCULATED
  VALIDATED_N1 // RH
  VALIDATED_N2 // DAF
  VALIDATED_N3 // DG
  PAID
  CANCELLED
}

model PayslipLine {
  id        String  @id @default(cuid())
  payslipId String
  payslip   Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  code           String // A001, A045, A050, A056-A072
  label          String // "Salaire de base", "IRPP", etc.
  quantity       Float? // 30 (jours)
  base           BigInt? // 6667
  rate           Float? // 4.20 pour CNPS
  amountPlus     BigInt? // colonne MONTANT+
  amountMinus    BigInt? // colonne MONTANT-
  employerAmount BigInt? // RET PATRON

  // Catégorie de la ligne pour grouper l'affichage sur le bulletin officiel
  // en 4 sections : GAINS, RETENUES (sociales/fiscales/autres), CHARGES PATRONALES.
  // Si null, la catégorie est dérivée du préfixe du code (01xx=GAIN, 31xx=DEDUCTION_SOCIAL,
  // 32xx=DEDUCTION_FISCAL, 33xx=DEDUCTION_OTHER, 41xx=EMPLOYER_SOCIAL, 42xx=EMPLOYER_OTHER).
  category PayslipLineCategory?

  order Int @default(0)

  @@index([payslipId])
  @@map("payslip_lines")
}

enum PayslipLineCategory {
  GAIN // 1. GAINS (salaire, primes, indemnités)
  DEDUCTION_SOCIAL // 2A. Retenues salariales — organismes sociaux (CNPS salarié, CAC, FNE)
  DEDUCTION_FISCAL // 2B. Retenues salariales — prélèvements fiscaux (IRPP)
  DEDUCTION_OTHER // 2C. Retenues salariales — autres (avances, prêts, absences)
  EMPLOYER_SOCIAL // 3A. Charges patronales — organismes sociaux (CNPS empl., CAC, FNE)
  EMPLOYER_OTHER // 3B. Charges patronales — autres (accident travail, médecine, formation)
}

// ========================================
// PORTAIL EMPLOI
// ========================================

model JobOffer {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  reference    String // REC-2026-008
  slug         String? // URL friendly (CAND Zone 2)
  title        String // Ingénieur travaux BTP
  department   String? // Direction Technique
  contractType ContractType
  category     String // Cadre, ETAM, OQ...
  positions    Int          @default(1)

  summary      String? @db.Text
  description  String  @db.Text
  requirements String  @db.Text

  // CAND Zone 2 — sections riches détail offre
  missions        Json? // string[] missions
  profileItems    Json? // string[] profil recherché
  benefits        Json? // string[] avantages
  experienceMin   Int? // années requises
  siteId          String? // chantier de rattachement
  hiringManagerId String?

  salaryMin BigInt?
  salaryMax BigInt?

  region      String?
  publishedAt DateTime?
  expiresAt   DateTime?
  status      JobStatus @default(DRAFT)
  viewCount   Int       @default(0)

  applications Application[]
  matches      JobMatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reference])
  @@unique([tenantId, slug])
  @@index([status, publishedAt])
  @@map("job_offers")
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model Application {
  id         String   @id @default(cuid())
  jobOfferId String
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  userId     String // candidat (User avec role=CANDIDATE)
  user       User     @relation(fields: [userId], references: [id])

  cvUrl       String?
  coverLetter String?  @db.Text
  score       Int? // 0-100, calculé par tri auto
  stage       AppStage @default(RECEIVED)
  notes       String?  @db.Text // notes RH internes

  // CAND fn 1.3
  rhMessage         String?   @db.Text // dernier message RH visible candidat
  lastStageChangeAt DateTime?
  withdrawnAt       DateTime?
  withdrawnReason   String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobOfferId, userId])
  @@map("applications")
}

enum AppStage {
  RECEIVED
  SHORTLISTED
  INTERVIEW
  TECHNICAL_TEST
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
  EXPIRED
}

// ========================================
// RH — Entretiens recrutement (RH Bloc 1 / fn 1.4)
// ========================================
model Interview {
  id            String             @id @default(cuid())
  applicationId String
  scheduledAt   DateTime
  duration      Int                @default(60) // minutes
  interviewers  String[] // userIds
  mode          InterviewMode      @default(ONSITE)
  location      String?
  completed     Boolean            @default(false)
  feedback      String?            @db.Text
  score         Int? // 1-5
  decision      InterviewDecision?

  // Confirmation candidat (CAND fn 1.1)
  candidateConfirmed   Boolean   @default(false)
  candidateConfirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId, scheduledAt])
  @@map("interviews")
}

enum InterviewMode {
  ONSITE
  PHONE
  VIDEO
}

enum InterviewDecision {
  GO
  NO_GO
  PENDING
}

// ========================================
// MESSAGERIE
// ========================================

model Conversation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String? // null pour DM, défini pour groupes
  isGroup     Boolean   @default(false)
  avatarUrl   String?
  // Phase 2 / Bloc 5 — fn 5.4
  isStrategic Boolean   @default(false)
  pinnedAt    DateTime?

  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, lastMessageAt])
  @@index([tenantId, isStrategic])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  isPinned   Boolean   @default(false)
  isMuted    Boolean   @default(false)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])

  content        String  @db.Text
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  // MIME type de la pièce jointe (image/png, application/pdf, audio/webm…).
  // Permet d'afficher le bon rendu côté bulle de message : preview image,
  // icône document ou player audio.
  attachmentType String?

  isSystem Boolean @default(false) // messages système type "X a partagé un document"

  // Phase 2 / Bloc 5 — fn 5.4
  priority            MessagePriority @default(NORMAL)
  mentions            String[] // userIds mentionnés
  attachedDocumentIds String[] // depuis GED
  pollData            Json? // { question, options: [{ label, votes: [userId] }] }

  voiceNote VoiceNote?

  // Suppression "pour tout le monde" (style WhatsApp) : on garde la ligne en
  // tombstone, on vide le contenu/pièce jointe et on affiche "message supprimé".
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, priority])
  @@map("messages")
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model VoiceNote {
  id        String  @id @default(cuid())
  messageId String  @unique
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  audioUrl    String
  durationSec Int
  transcript  String? @db.Text

  createdAt DateTime @default(now())

  @@map("voice_notes")
}

// ========================================
// COMPTABILITÉ DAF (Phase 2 / DAF Bloc 2 — fn 2.1)
// ========================================
// Rapprochements bancaires + checklist clôture mensuelle.
model BankReconciliation {
  id              String               @id @default(cuid())
  tenantId        String
  bankAccountId   String
  period          String // "2026-04"
  bookBalance     BigInt
  bankBalance     BigInt
  gap             BigInt               @default(0)
  reconciledItems Json                 @default("[]") // ids des entries pointées
  status          ReconciliationStatus @default(PENDING)
  completedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, bankAccountId, period])
  @@index([tenantId, status])
  @@map("bank_reconciliations")
}

enum ReconciliationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  VALIDATED
}

model MonthlyClosingChecklist {
  id       String        @id @default(cuid())
  tenantId String
  period   String
  items    Json          @default("[]") // [{ key, label, status, completedAt, by }]
  status   ClosingStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@map("monthly_closings")
}

enum ClosingStatus {
  OPEN
  IN_PROGRESS
  READY
  CLOSED
}

// ========================================
// FINANCES DAF — Analyse profonde (DAF Bloc 2 / fn 2.2)
// ========================================
model BudgetVariance {
  id              String    @id @default(cuid())
  tenantId        String
  period          String
  costCenter      String // "Achats matières", "Personnel", "Sous-traitance"...
  budgetAmount    BigInt
  actualAmount    BigInt
  variance        BigInt    @default(0)
  variancePercent Float     @default(0)
  comment         String?   @db.Text
  commentAuthor   String?
  commentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period, costCenter])
  @@index([tenantId, period])
  @@map("budget_variances")
}

model FinancialScenario {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  parameters  Json // hypothèses
  results     Json // P&L, BFR, treasury impact
  authorId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("financial_scenarios")
}

// ========================================
// ACHATS DAF — Engagements (DAF Bloc 2 / fn 2.3)
// ========================================
model SupplierCommitment {
  id                   String                   @id @default(cuid())
  tenantId             String
  supplierId           String
  supplierObj          Supplier                 @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  poRef                String
  amount               BigInt
  deliveredAmount      BigInt                   @default(0)
  invoicedAmount       BigInt                   @default(0)
  expectedDeliveryDate DateTime?
  status               SupplierCommitmentStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([supplierId])
  @@map("supplier_commitments")
}

enum SupplierCommitmentStatus {
  ACTIVE
  PARTIAL_DELIVERY
  FULFILLED
  CANCELLED
}

// ========================================
// CYCLE DE PAIE DAF (Phase 2 / DAF Bloc 1 — fn 1.4)
// ========================================
// Pilote le cycle mensuel de paie : 7 statuts du calcul à la transmission DIPE.
model PayrollCycle {
  id       String             @id @default(cuid())
  tenantId String
  period   String // "2026-04"
  status   PayrollCycleStatus @default(DRAFT)

  totalBulletins  Int    @default(0)
  grossAmount     BigInt @default(0)
  employerCharges BigInt @default(0)
  netToPay        BigInt @default(0)

  startedAt       DateTime
  calculatedAt    DateTime?
  n1ValidatedAt   DateTime?
  n2ValidatedAt   DateTime?
  n3ValidatedAt   DateTime?
  paidAt          DateTime?
  dipeSubmittedAt DateTime?

  warnings Json @default("[]") // [{ severity, type, message, count? }]

  inputs            PayrollInput[]
  payslips          Payslip[]
  employeeSnapshots PayrollEmployeeSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@map("payroll_cycles")
}

enum PayrollCycleStatus {
  DRAFT
  CALCULATING
  CALCULATED
  N1_PENDING
  N2_PENDING
  N3_PENDING
  PAID
  DIPE_SUBMITTED
  CLOSED
}

// ========================================
// RH DAF — Provisions sociales et départs (DAF Bloc 3 / fn 3.3)
// ========================================
model SocialProvision {
  id           String        @id @default(cuid())
  tenantId     String
  type         ProvisionType
  amount       BigInt
  calculatedAt DateTime      @default(now())
  periodEnd    String // exercice concerné
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, periodEnd])
  @@map("social_provisions")
}

enum ProvisionType {
  PAID_LEAVE // Congés payés
  END_OF_CAREER // Indemnités fin de carrière (IFC)
  BONUSES // Primes
  MUTUAL // Mutuelle / prévoyance
  OTHER
}

model EmployeeDeparture {
  id             String          @id @default(cuid())
  tenantId       String
  userId         String
  employeeName   String // snapshot du nom au moment du départ
  position       String?
  departureType  DepartureType
  departureDate  DateTime
  severancePay   BigInt          @default(0)
  unusedLeavePay BigInt          @default(0)
  bonusProrata   BigInt          @default(0)
  totalCost      BigInt          @default(0)
  status         DepartureStatus @default(PROVISIONED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, departureDate])
