// ========================================
// OUV — Espace Ouvrier (Bloc 0 Ouvrier)
// ========================================
// Quatre modèles dédiés à l'ouvrier de base (Étienne MBALLA) :
//   - SalaryAdvanceRequest : avance sur salaire (max 30% salaire base)
//   - MissionAssignment    : ordres de mission affectés par CC/DTrav
//   - HseIncidentReport    : signalement HSE par l'ouvrier (anti-représailles)
//   - EpiAssignment        : suivi équipements de protection individuels
// Les modèles TimeReport et LeaveRequest existants sont réutilisés tels quels.

model SalaryAdvanceRequest {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User                @relation("SalaryAdvanceRequester", fields: [userId], references: [id], onDelete: Cascade)
  amountXAF       BigInt
  reason          String?
  maxAllowedXAF   BigInt // 30% × salaire base (calculé au moment de la demande)
  status          SalaryAdvanceStatus @default(PENDING)
  // Validation : auto (< 50K), RH (50-100K), DAF (100-200K), DG (> 200K)
  validatedById   String?
  validator       User?               @relation("SalaryAdvanceValidator", fields: [validatedById], references: [id])
  validatedAt     DateTime?
  rejectionReason String?
  // Paiement
  payoutAt        DateTime?
  payoutMethod    String? // BANK_TRANSFER | MOBILE_MONEY | CASH
  // Récupération sur paie
  recoveryMonth   String? // "2026-05"
  recoveredAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId, createdAt])
  @@map("salary_advance_requests")
}

enum SalaryAdvanceStatus {
  PENDING
  APPROVED
  PAID
  RECOVERED
  REJECTED
  CANCELLED
}

model MissionAssignment {
  id                    String          @id @default(cuid())
  tenantId              String
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String // ouvrier affecté
  user                  User            @relation("MissionWorker", fields: [userId], references: [id], onDelete: Cascade)
  siteId                String
  site                  Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assignedById          String // CC ou DTrav
  assignedBy            User            @relation("MissionAssigner", fields: [assignedById], references: [id])
  title                 String
  description           String          @db.Text
  instructions          String?         @db.Text // consigne chef
  startDate             DateTime
  endDate               DateTime?
  estimatedDays         Int?
  progressPercent       Int             @default(0)
  priority              MissionPriority @default(NORMAL)
  status                MissionStatus   @default(PENDING_ACCEPTANCE)
  // Acceptation par ouvrier
  workerAcceptedAt      DateTime?
  workerQuestionsRaised String?         @db.Text
  // Clôture
  completedAt           DateTime?
  completionNotes       String?
  progressPhotoUrls     String[]        @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([siteId, status])
  @@map("mission_assignments")
}

enum MissionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MissionStatus {
  PENDING_ACCEPTANCE
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model HseIncidentReport {
