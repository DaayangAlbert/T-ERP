  invoiceNumber String
  invoiceDate   DateTime
  dueDate       DateTime
  amountHt      BigInt
  vatAmount     BigInt
  amountTtc     BigInt

  siteId      String?
  site        Site?   @relation("InvoiceSite", fields: [siteId], references: [id])
  poRef       String?
  deliveryRef String?

