// ========================================
// OUV — Attestations RH (Bloc 1 Ouvrier fn 1.4)
// ========================================
// L'ouvrier demande une attestation (salaire, travail, présence, congé pris,
// autre). RH (Sandrine ONANA · role HR) prépare le PDF signé sous 48 h
// ouvrées, l'upload sur R2 puis marque READY. L'ouvrier reçoit notification
// WhatsApp et télécharge depuis l'app.

model AttestationRequest {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String // ouvrier demandeur
  user            User              @relation("AttestationRequester", fields: [userId], references: [id], onDelete: Cascade)
  type            AttestationType
  purpose         String? // pour quoi faire ? ex : "ouverture compte Afriland", "dossier visa"
  status          AttestationStatus @default(PENDING)
  // Préparation côté RH
  preparedById    String? // RH ou Comptable qui a préparé le PDF
  preparedBy      User?             @relation("AttestationPreparer", fields: [preparedById], references: [id])
  preparedAt      DateTime?
  documentUrl     String? // URL R2 du PDF signé
  // Échéance attendue (48h ouvrées après requestedAt) — recalculée si besoin
  expectedReadyAt DateTime?
  // Refus / annulation
  rejectionReason String?
  // Remise effective à l'ouvrier (téléchargement ou impression)
  deliveredAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId, createdAt])
  @@map("attestation_requests")
}

enum AttestationType {
  SALARY // attestation de salaire
  EMPLOYMENT // attestation de travail
  PRESENCE // attestation de présence
  LEAVE_TAKEN // attestation de congés pris
  OTHER
}

enum AttestationStatus {
  PENDING
  IN_PREPARATION
  READY
  DELIVERED
  REJECTED
  CANCELLED
}

// ========================================
// OUV — Prêts d'outils ouvrier (Bloc 1 Ouvrier fn 1.8)
// ========================================
// Workflow simple : ouvrier demande un outil → magasinier (Lucas TIENTCHEU)
// le délivre → ouvrier le rend. Couvre demande + prêt en cours + retour.
// Pour les outils prêtés en permanent (mètre ruban, casquette de marque)
// → `isPermanent: true`, pas de dueDate.

model ToolLoan {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String // ouvrier emprunteur
  user          User           @relation("ToolLoanBorrower", fields: [userId], references: [id], onDelete: Cascade)
  toolName      String // libellé court : "Marteau de coffreur"
  toolCategory  String? // optionnel : "Coffrage", "Mesure", "Niveau"
  serialNumber  String? // si applicable
  // Workflow
  status        ToolLoanStatus @default(REQUESTED)
  requestedAt   DateTime       @default(now())
  requestReason String? // motif demande
  issuedAt      DateTime?
  issuedById    String? // magasinier
  issuedBy      User?          @relation("ToolLoanIssuer", fields: [issuedById], references: [id])
  dueDate       DateTime? // null si isPermanent = true
  isPermanent   Boolean        @default(false)
  returnedAt    DateTime?
  notes         String? // remarques magasinier ou ouvrier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([userId, status])
  @@map("tool_loans")
}

enum ToolLoanStatus {
  REQUESTED
  ISSUED
  RETURNED
  OVERDUE
  LOST
  CANCELLED
}

// ============================================================================
// CHEF CHANTIER — Bloc Rapports d'avancement (Module 2)
// ============================================================================
// Le CC produit périodiquement un rapport structuré (hebdo, mensuel, ad hoc)
// pour son DTrav. Validation N+1 par le Directeur de Travaux. Notifie le DG
// en info. Export PDF officiel via @react-pdf/renderer.

model SiteProgressReport {
  id          String                   @id @default(cuid())
  tenantId    String
  siteId      String
  site        Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId    String
  author      User                     @relation("ProgressReportAuthor", fields: [authorId], references: [id])
  reportType  SiteProgressReportType   @default(MONTHLY)
  period      DateTime // 1er du mois ou début de semaine
  periodLabel String? // "2026-05" ou "2026-W21"
  status      SiteProgressReportStatus @default(DRAFT)

  // Étape 1 — Avancement physique
  physicalProgressPercent Float  @default(0)
  previousProgressPercent Float?

  // Étape 2 — Réalisations & retards
  mainAchievements String?  @db.Text
  delaysIdentified String?  @db.Text
  photos           String[] @default([])

  // Étape 3 — Financier & RH
  valueProducedXAF      BigInt  @default(0)
  valueProducedCumulXAF BigInt  @default(0)
  avgWorkforce          Int     @default(0)
  maxWorkforce          Int     @default(0)
  overtimeHoursTotal    Float   @default(0)
  billingStatus         String? @db.Text

  // Étape 4 — HSE & problèmes
  hseIncidentsCount   Int     @default(0)
  daysWithoutAccident Int     @default(0)
  issuesEncountered   String? @db.Text
  supportNeeded       String? @db.Text

  // Étape 5 — Pièces jointes & priorités
  attachmentDocumentIds String[] @default([]) // FK SiteDocument
  nextPeriodPriorities  String?  @db.Text

  // Workflow
  submittedAt     DateTime?
  validatedById   String?
  validatedBy     User?     @relation("ProgressReportValidator", fields: [validatedById], references: [id])
  validatedAt     DateTime?
  rejectionReason String?   @db.Text

  pdfUrl String? // URL du dernier PDF généré (cache optionnel)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, period])
  @@index([siteId, status])
  @@index([authorId])
  @@index([validatedById])
  @@map("site_progress_reports")
}

enum SiteProgressReportType {
  WEEKLY
  MONTHLY
  AD_HOC
}

enum SiteProgressReportStatus {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
}

