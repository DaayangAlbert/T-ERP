// ========================================
// NOTIFICATIONS
// ========================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String // payslip_ready, validation_required, message_received...
  title String
  body  String?
  link  String? // chemin app à ouvrir

  read   Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ========================================
// AUDIT TRAIL
// ========================================

model AuditLog {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  userId   String?
  user     User?   @relation(fields: [userId], references: [id])

  action     String // user.login, payslip.validate, site.update...
  entityType String?
  entityId   String?
  metadata   Json? // données contextuelles (avant/après, IP, user-agent...)

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ========================================
// VALIDATIONS DG (Phase 2 / Bloc 2 — fn 2.1)
// ========================================
// Demandes nécessitant l'approbation d'un cadre (paie, dépense, achat,
// embauche, marché, congé). Chaque demande porte un workflow JSON avec
// les étapes (initiateur → N1 → N2 → N3) et leurs dates de validation.
model Validation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        ValidationType
  reference   String // VAL-2026-0042
  title       String
  description String?        @db.Text
  amount      BigInt? // FCFA si applicable

  initiatorId String
  initiator   User   @relation("ValidationInitiator", fields: [initiatorId], references: [id])

  // Étape courante du workflow (par convention : "RH" | "DAF" | "DG")
  currentStep       String?
  currentApproverId String?
  currentApprover   User?   @relation("ValidationCurrentApprover", fields: [currentApproverId], references: [id])

  // Workflow complet (étapes + dates) — { steps: [{ key, label, role, status, decidedBy?, decidedAt? }] }
  workflow Json
  // Historique commentaires + demandes justification + délégations
  comments Json @default("[]")

  status   ValidationStatus   @default(PENDING)
  priority ValidationPriority @default(NORMAL)

  decidedById    String?
  decidedBy      User?     @relation("ValidationDecidedBy", fields: [decidedById], references: [id])
  decisionAt     DateTime?
  decisionReason String?   @db.Text

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // DT — fn 1.4 : N2 technique (avenants, sous-traitance > 30 M, marchés méthode spéciale...)
  dtValidationRequired Boolean   @default(false)
  dtValidatedAt        DateTime?
  dtValidatedBy        String?
  dtComments           String?   @db.Text
  dtAttachments        String[]  @default([])

  // Escalade au Propriétaire / PCA (gouvernance). Seul le DG peut demander
  // l'autorisation du PCA ; après accord du PCA, le DG confirme sa validation.
  // ownerDecision : null = non escaladé · "PENDING" = en attente PCA ·
  // "APPROVED"/"REJECTED" = avis rendu par le PCA.
  ownerEscalatedAt   DateTime?
  ownerEscalatedById String?
  ownerDecision      String?
  ownerDecisionAt    DateTime?
  ownerDecisionById  String?
  ownerDecisionReason String?  @db.Text

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([currentApproverId, status])
  @@index([tenantId, type, status])
  @@map("validations")
}

enum ValidationType {
  PAYROLL
  EXPENSE
  PURCHASE
  HIRING
  CONTRACT
  LEAVE
  OTHER
  // DT — fn 1.4 : types techniques validés en N2 par le DT
  AMENDMENT // avenant marché client
  SUBCONTRACTING // sous-traitance > 30 M
  EQUIPMENT // acquisition matériel > 30 M
  SPECIAL_METHOD // méthode spéciale (coffrage glissant, technique non-standard)
  TECHNICAL_HANDOVER // mise en service technique (essais, réceptions)
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum ValidationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Délégations ponctuelles ou permanentes : un cadre délègue ses pouvoirs
// d'approbation à un autre, pour certains types et jusqu'à un montant max.
model Delegation {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fromUserId String
  fromUser   User   @relation("DelegationFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User   @relation("DelegationTo", fields: [toUserId], references: [id])

  types     ValidationType[]
  maxAmount BigInt?
  startDate DateTime
  endDate   DateTime?
  active    Boolean          @default(true)
  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@index([fromUserId, active])
  @@map("delegations")
}

// ========================================
// RAPPORTS CONSOLIDÉS DG (Phase 2 / Bloc 2 — fn 2.2)
// ========================================
// Rapports stratégiques générés par le DG : synthèse exécutive, tableau
// de bord mensuel, bilan annuel, note trimestrielle, rapport sur-mesure.
// Le wizard permet de configurer les blocs (KPIs, graphes, tableaux) et
// d'envoyer le rapport par email aux destinataires.
model Report {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  type          ReportType
  title         String
  period        String // "S18-2026", "2026-04", "2026-T1"...
  parameters    Json // { scope, start, end, ... }
  blocks        Json // [{ type, label, ... }] — bibliothèque de blocs
  data          Json // snapshot des données calculées au moment de la génération
  pdfUrl        String?
  status        ReportStatus @default(GENERATED)
  scheduledRule String? // cron-like si rapport planifié
  recipients    Json? // [{ email, name, sentAt }]
  generatedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("reports")
}

enum ReportType {
  EXECUTIVE_SUMMARY // Synthèse exécutive hebdo (DG)
  MONTHLY_DASHBOARD // Tableau de bord stratégique mensuel (DG)
  ANNUAL_GROUP // Bilan annuel groupe (DG)
  QUARTERLY_NOTE // Note d'activité trimestrielle (DG)
  CUSTOM // Sur-mesure (DG/DAF)
  // DAF Bloc 3 / fn 3.2 — Reportings financiers DAF
  DAF_TREASURY_WEEKLY // Tableau de bord trésorerie envoyé chaque lundi 6h au DG
  DAF_FINANCIAL_MONTHLY // Synthèse mensuelle (P&L + BFR + Tréso) le 5 du mois
  DAF_BANKING_QUARTERLY // Reporting bancaire trimestriel (relationship managers)
  DAF_CAC_QUARTERLY // Reporting CAC trimestriel (commissaires aux comptes)
  DAF_DSF_PREP // Préparation DSF (états financiers OHADA annuels)
  // RH Bloc 2 / fn 2.2 — Reportings RH
  RH_MONTHLY // Rapport mensuel d'activité RH (pour le DG)
  RH_SOCIAL_ANNUAL // Bilan social annuel (obligation légale)
  RH_GENDER_EQUALITY // Rapport égalité H/F (obligation légale)
  RH_WEEKLY_DASHBOARD // Tableau de bord RH hebdomadaire (interne)
  RH_RECRUITMENT_QUARTERLY // Statistiques recrutement trimestriel
  RH_SOCIAL_INDICATORS // Indicateurs sociaux (turnover, absentéisme, climat)
  // Comptable Bloc 2 / fn 2.2 — Rapports comptables (Direction + Chantier)
  CPT_GENERAL_LEDGER
  CPT_BALANCE_GENERAL
  CPT_BALANCE_AUX_SUPPLIERS
  CPT_BALANCE_AUX_CUSTOMERS
  CPT_JOURNAL_CENTRALIZER
  CPT_MONTHLY_SYNTHESIS
  CPT_DSF_PREP
  CPT_AGED_BALANCE_SUPPLIERS
  CPT_AGED_BALANCE_CUSTOMERS
  CPT_ANALYTICAL_CONSOLIDATED
  CPT_SITE_LEDGER
  CPT_SITE_BALANCE
  CPT_SITE_EXPENSES
  CPT_SITE_BILLINGS
  CPT_SITE_MONTHLY
  // DT Bloc 2 / fn 2.2 — Rapports techniques DT
  DT_WEEKLY_TECHNICAL // Reporting hebdo technique (lundi 7h au DG)
  DT_MONTHLY_PRODUCTION // Reporting mensuel production (tableau comparatif chantiers)
  DT_QUARTERLY_TECHNICAL // Bilan technique trimestriel (COMEX + CA)
  DT_HSE_MONTHLY // Rapport sinistralité HSE (CHSCT)
  DT_TENDERS_QUARTERLY // Études et taux de transformation
  DT_ISO_ANNUAL // Bilan certifications ISO
  DT_MOA_MONTHLY // Reporting MOA par chantier
}

enum ReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

// ========================================
// CONFIGURATION TENANT (Phase 2 / Bloc 2 — fn 2.3)
// ========================================
// Paramétrage du tenant par le DG : identité, modules actifs, plan
// comptable, paramètres paie, workflows de validation, notifications,
// intégrations API. Une seule ligne par tenant.
model TenantSettings {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  identity      Json // raison sociale, NIU, RCCM, capital, sièges, représentants
  modules       Json // { msg: true, payroll: true, ... }
  payrollRates  Json // barèmes IRPP + taux CNPS/CFC/FNE/RAV/TC/CAC/CFS
  workflows     Json // règles de validation par type
  notifications Json // matrice destinataires × événements × canaux
  integrations  Json // clés API (chiffrées) — banques, CNPS, MoMo, Resend

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("tenant_settings")
}

// ========================================
// SESSIONS UTILISATEUR (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Sessions actives suivies pour permettre au DG de voir qui est connecté
// et déconnecter à distance. Une session ≠ un JWT : c'est une trace
// d'identification (IP, user-agent, géoloc).
model Session {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress      String?
  userAgent      String?
  location       String? // résolu via API IP geolocation
  suspicious     Boolean   @default(false)
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, expiresAt])
  @@map("sessions")
}

// ========================================
// RÔLES PERSONNALISÉS (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Permet de cloner un rôle système et d'ajuster ses permissions pour un
// tenant donné (ex: "Validateur dérogatoire", "Auditeur externe").
model CustomRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  basedOn     Role
  permissions Json // { sites: ["read"], payroll: ["read", "write"], ... }
  userCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("custom_roles")
}

// ========================================
// CHANTIERS — VUE DG TRANSVERSE (Phase 2 / Bloc 3 — fn 3.1)
// ========================================
// Contrats de marché (initialAmount + avenants), photos chantier,
// alertes (dérives budget, retards, HSE) et décisions DG enregistrées.
model SiteContract {
  id     String @id @default(cuid())
  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  reference       String
  initialAmount   BigInt
  currentAmount   BigInt
  amendments      Json      @default("[]") // [{ ref, amount, date, reason, validatedBy }]
  guarantees      Json      @default("{}") // { caution, retention, penalties }
  paymentTerms    String?
  publicMarket    Boolean   @default(false)
  procuringEntity String? // MINTP, MINHDU, FEICOM...
  signedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_contracts")
}

model SitePhoto {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  takenAt    DateTime
  uploadedBy String

  createdAt DateTime @default(now())

  @@index([siteId, takenAt])
  @@map("site_photos")
}

model SiteAlert {
  id          String        @id @default(cuid())
  siteId      String
  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  severity    AlertSeverity
  type        String // BUDGET_OVERRUN, DELAY, HSE_INCIDENT, MARGIN_DROP, ...
  message     String
  // DTrav fn 1.1 — affichage hiérarchisé + CTA direct
  priority    AlertPriority @default(NORMAL)
  actionUrl   String?
  actionLabel String?
  resolved    Boolean       @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([siteId, resolved])
  @@map("site_alerts")
}

enum AlertPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SiteDecision {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@map("site_decisions")
}

// ========================================
// PLANNING DG (Phase 2 / Bloc 3 — fn 3.2)
// ========================================
// Jalons stratégiques (réceptions, lancements, échéances fiscales, AG…)
// + conflits ressources détectés (surcharges) à arbitrer par le DG.
model Milestone {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId   String? // optionnel : jalon d'un chantier précis
  type     MilestoneType
  title    String
  date     DateTime
  critical Boolean         @default(false)
  status   MilestoneStatus @default(PLANNED)
  notes    String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, type])
  @@map("milestones")
}

enum MilestoneType {
  SITE_START
  SITE_DELIVERY
  MILESTONE
  FINANCIAL
  COMMERCIAL
  INTERNAL
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  DONE
  DELAYED
  CANCELLED
}

model ResourceConflict {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  resourceType      String // CREW, EQUIPMENT
  resourceLabel     String // "Maçons coffreurs", "Pelle hydraulique 20T"...
  periodStart       DateTime
  periodEnd         DateTime
  demandLevel       Int // % de surcharge (>100 = saturé)
  siteIds           String[] // chantiers concernés
  resolved          Boolean           @default(false)
  resolution        String?           @db.Text
  arbitration       Boolean           @default(false) // demande arbitrage DG
  arbitrationStatus ArbitrationStatus @default(PENDING)
  arbitrationNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, resolved])
  @@index([tenantId, arbitration])
  @@map("resource_conflicts")
}

enum ArbitrationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ========================================
// RH STRATÉGIQUE DG (Phase 2 / Bloc 3 — fn 3.3)
// ========================================
// Plan de succession pour les postes clés, formations historiques /
// planifiées (avec recyclages CACES), indicateurs sociaux mensuels.
model SuccessionPlan {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  positionTitle String // "Directeur de travaux", "DAF"...
  incumbentId   String
  incumbent     User             @relation("SuccessionIncumbent", fields: [incumbentId], references: [id])
  successorId   String?
  successor     User?            @relation("SuccessionSuccessor", fields: [successorId], references: [id])
  readyInMonths Int?
  status        SuccessionStatus @default(NONE)
  notes         String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, positionTitle])
  @@index([tenantId, status])
  @@map("succession_plans")
}

enum SuccessionStatus {
  IDENTIFIED
  AT_RISK
  NONE
  READY_NOW
}

model Training {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Rattachement optionnel à une session de formation (groupe). Si null,
  // c'est une formation individuelle (formation interne, e-learning, etc.).
  sessionId String?
  session   TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  title          String
  category       String // CACES, sécurité, métier, management...
  provider       String?
  startDate      DateTime
  endDate        DateTime
  cost           BigInt?
  status         TrainingStatus @default(PLANNED)
  certificateUrl String?
  expiresAt      DateTime? // pour recyclage obligatoire

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@index([sessionId])
  @@map("trainings")
}

// Session de formation collective (8 participants, dates de groupe…).
// Référence : RH 1.6 — Plan annuel de formation. Une TrainingSession peut
// avoir N inscriptions individuelles (modèle Training) reliées via sessionId.
model TrainingSession {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  ref                  String // ex: "FORM-2026-001"
  title                String
  category             String // CACES, SAFETY, TECHNICAL, MANAGEMENT, LANGUAGES
  provider             String?
  startDate            DateTime
  endDate              DateTime
  expectedParticipants Int            @default(0)
  budget               BigInt         @default(0)
  status               TrainingStatus @default(PLANNED)
  location             String?
  notes                String?

  trainings Training[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, ref])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
  @@map("training_sessions")
}

enum TrainingStatus {
  PLANNED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model SocialIndicator {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period     String // "2026-04"
  // Stocké en JSON pour souplesse : turnover, absenteeism, climate, conflicts...
  indicators Json

  createdAt DateTime @default(now())

  @@unique([tenantId, period])
  @@map("social_indicators")
}

// ========================================
// FINANCES DG (Phase 2 / Bloc 4 — fn 4.1)
// ========================================
// Snapshot mensuel : compte de résultat (P&L), bilan synthétique, BFR.
// Une ligne par mois. Verrouillage après clôture comptable.
model FinancialPeriod {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period  String // "2026-04" ou "2026-BUDGET" pour budget
  pnl     Json // { products: {...}, expenses: {...}, results: {...} }
  balance Json // { actif: {...}, passif: {...}, ratios: {...} }
  bfr     Json // { dso, dpo, stockRotation, bfr, treasury }
  locked  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, period])
  @@map("financial_periods")
}

// Engagements financiers : cautions, GAPD, lettres de crédit, BC long terme.
model FinancialCommitment {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         CommitmentType
  reference    String?
  bank         String?
  beneficiary  String?
  amount       BigInt
  siteId       String?
  issueDate    DateTime
  maturityDate DateTime
  status       CommitmentStatus @default(ACTIVE)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("financial_commitments")
}

enum CommitmentType {
  BANK_GUARANTEE
  FIRST_DEMAND_GUARANTEE
  LETTER_CREDIT
  PURCHASE_COMMITMENT
}

enum CommitmentStatus {
  ACTIVE
  EXPIRED
  RELEASED
  CALLED
}

// Comptes bancaires : solde JJ + lignes accordées/utilisées + relation manager.
// Étendu DAF (Bloc 1 / fn 1.2) : syncStatus + lastSyncAt + primaryColor + movements.
model BankAccount {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bank              String // UBA, BICEC, AFRILAND, ECOBANK, SGBC...
  accountNumber     String
  accountType       String    @default("CURRENT") // CURRENT, ESCROW, SAVING, GUARANTEE, FOREIGN_CURRENCY
  currency          String    @default("XAF")
  balance           BigInt
  creditLineGranted BigInt    @default(0)
  creditLineUsed    BigInt    @default(0)
  renewalDate       DateTime?
  contact           Json? // { name, phone, email }
  history12m        Json      @default("[]") // [{ month, balance }]

  // DAF fn 1.2 — synchro temps réel
  lastSyncAt   DateTime?
  syncStatus   BankSyncStatus @default(MANUAL)
  primaryColor String? // pour code couleur visuel UBA rouge, BICEC sarcelle...

  // Cycle de vie : un compte clôturé reste en base (historique des mouvements)
  // mais sort des positions consolidées et n'est plus approvisionnable.
  isActive Boolean   @default(true)
  closedAt DateTime?

  movements       BankMovement[]
  projectAccounts ProjectAccount[]
  salaryAccounts  SalaryAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
  @@map("bank_accounts")
}

enum BankSyncStatus {
  LIVE
  DELAYED
  MANUAL
  ERROR
}

// Mouvements bancaires (DAF Bloc 1 / fn 1.2). Trace des entrées / sorties par compte.
model BankMovement {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  direction    MovementDirection
  amount       BigInt
  label        String
  reference    String?
  counterparty String?
  siteId       String?
  occurredAt   DateTime

  createdAt DateTime @default(now())

  @@index([bankAccountId, occurredAt])
  @@map("bank_movements")
}

enum MovementDirection {
  INBOUND
  OUTBOUND
}

// ========================================
// COMPTABILITÉ DG (Phase 2 / Bloc 4 — fn 4.2)
// ========================================
// Périodes comptables (mensuelles + clôture annuelle), écritures
// SYSCOHADA. V1 : structure conforme, calcul brouillon — validation
// expert-comptable agréé OHADA requise pour la prod.
model AccountingPeriod {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period       String // "2026-04" ou "2026" pour annuel
  status       PeriodStatus @default(OPEN)
  closedAt     DateTime?
  closedBy     String?
  totalEntries Int          @default(0)
  totalDebit   BigInt       @default(0)
  totalCredit  BigInt       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@map("accounting_periods")
}

enum PeriodStatus {
  OPEN
  CLOSING
  CLOSED
  LOCKED
}

// Écriture comptable simplifiée (V1) avec lignes débit/crédit.
model AccountingEntry {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period      String // "2026-04"
  reference   String // PIE-2026-001
  date        DateTime
  journal     String // OD, AC, BQ, VE, OD
  label       String
  totalDebit  BigInt
  totalCredit BigInt

  // DAF Bloc 2 / fn 2.1 — supervision DAF
  status                EntryStatus @default(VALIDATED)
  validatedByDaf        Boolean     @default(true)
  dafValidatedAt        DateTime?
  dafValidatedBy        String?
  requiresDafValidation Boolean     @default(false)
  enteredBy             String? // userId du saisisseur

  lines     AccountingLine[]
  createdAt DateTime         @default(now())

  @@unique([tenantId, reference])
  @@index([tenantId, period])
  @@index([tenantId, status])
  @@map("accounting_entries")
}

enum EntryStatus {
  DRAFT
  VALIDATED
  LOCKED
  REVERSED
}

model AccountingLine {
  id      String          @id @default(cuid())
  entryId String
  entry   AccountingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  account String // numéro SYSCOHADA (4 à 6 chiffres)
  label   String
  debit   BigInt @default(0)
  credit  BigInt @default(0)

  @@index([account])
  @@map("accounting_lines")
}

// Clôture annuelle avec workflow DG en 5 étapes.
model AnnualClosure {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fiscalYear           Int
  status               ClosureStatus @default(IN_PROGRESS)
  pnlValidated         Boolean       @default(false)
  balanceValidated     Boolean       @default(false)
  adjustmentsValidated Boolean       @default(false)
  draftGenerated       Boolean       @default(false)
  adjustments          Json          @default("[]")
  dgValidatedAt        DateTime?
  dgValidatedBy        String?
  submittedToDgi       Boolean       @default(false)
  dsfFileUrl           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, fiscalYear])
  @@map("annual_closures")
}

enum ClosureStatus {
  IN_PROGRESS
  PENDING_DG_VALIDATION
  VALIDATED
  SUBMITTED
}

// ========================================
// ACHATS DG (Phase 2 / Bloc 4 — fn 4.3)
// ========================================
// Fournisseurs, contrats-cadres, BC en attente validation DG, évaluations.
model Supplier {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  category      String // Ciment, Acier, Carburant, Engins, Sous-traitance...
  taxId         String? // NIU
  rccm          String?
  phone         String?
  email         String?
  address       String?
  city          String? // ville/agglomération principale (Douala, Yaoundé, Bafoussam...)
  paymentTerms  Int     @default(45) // jours
  ratingQuality Float? // 1-5
  ratingDelay   Float?
  ratingPrice   Float?
  strategic     Boolean @default(false)
  blocked       Boolean @default(false)
  blockReason   String?
  volumeYTD     BigInt  @default(0)
  poCount       Int     @default(0)

  // DAF Bloc 2 / fn 2.3 — suivi financier fournisseur
  paymentTermsContract  Int     @default(45)
  paymentTermsActual    Int     @default(0)
  financialRating       String?
  financialRatingSource String?
  incidentsCount        Int     @default(0)

  // DT — fn 1.7 : sous-traitance technique
  isSubcontractor  Boolean        @default(false)
  specialties      SubSpecialty[] @default([])
  agreements       String[]       @default([]) // certifications, agréments métier
  internalRating   Float          @default(0) // 0-5 (moyenne SubcontractorEvaluation.overallScore)
  ratingsCount     Int            @default(0)
  fiscalCompliance Json? // { cnps: 'OK'|'KO'|'PENDING', dgi: '...', lastChecked: ISO }
  alertNotes       String?

  contracts      FrameworkContract[]
  evaluations    SupplierEvaluation[]
  purchaseOrders PurchaseOrder[]
  commitments    SupplierCommitment[]
  invoices       SupplierInvoice[]
  // DT — relations sous-traitance
  subEvaluations SubcontractorEvaluation[]
  // CDT — présences sous-traitants journalières
  presences      SubcontractorPresence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, strategic])
  @@index([tenantId, category])
  @@index([tenantId, isSubcontractor])
  @@map("suppliers")
}

// DT — fn 1.7 : spécialités sous-traitance technique
enum SubSpecialty {
  EARTHWORKS_HEAVY
  ROOFING_WATERPROOFING
  ELECTRICAL
  PLUMBING
  HVAC
  PAINTING
  TILING
  JOINERY
  METALWORK
  GLAZING
  DEMOLITION
  CRANE
  OTHER
}

model FrameworkContract {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  reference  String
  subject    String
  maxAmount  BigInt
  usedAmount BigInt         @default(0)
  startDate  DateTime
  endDate    DateTime
  conditions Json?
  status     ContractStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@map("framework_contracts")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model SupplierEvaluation {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  evaluatorId   String
  period        String
  ratingQuality Float
  ratingDelay   Float
  ratingPrice   Float
  comments      String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([supplierId, createdAt])
  @@map("supplier_evaluations")
}

// Bons de commande avec workflow validation DG (montant > seuil)
model PurchaseOrder {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  // DTrav fn 1.6 — rattachement chantier (null = siège)
  siteId     String?

  reference        String
  label            String
  amount           BigInt
  category         String
  // Lignes d'articles du bon : [{ designation, quantity, unitPrice, amount }]
  lines            Json      @default("[]")
  initiatorId      String
  status           PoStatus  @default(PENDING_DAF)
  // DTrav fn 1.6 — validation N1 par le DTrav
  dtravValidatedAt DateTime?
  dtravValidatedBy String?
  dafApprovedAt    DateTime?
  dafApprovedBy    String?
  dgDecisionAt     DateTime?
  dgDecisionBy     String?
  dgDecisionNote   String?
  rejectionReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([siteId])
  @@map("purchase_orders")
}

enum PoStatus {
  DRAFT
  PENDING_DAF
  PENDING_DG
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// STOCKS & MATÉRIEL DG (Phase 2 / Bloc 5 — fn 5.1)
