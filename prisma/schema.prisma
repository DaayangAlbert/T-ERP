// ============================================================
// DT — DIRECTION TECHNIQUE (Bloc 0 + 1 + 2)
// ============================================================
// Daniel ESSOMBA — supervise 23 chantiers, 4 directeurs travaux,
// pipeline d'études, méthodes, plan de charge, sous-traitance, QHSE.
// ============================================================

// Bloc 0 — Préférences personnelles DT (alertes, layout)
model DtSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  alertsConfig    Json? // { costDeviationThreshold, delayThresholdDays, marginThresholdPercent, ... }
  dashboardLayout Json? // [{ widget, order, size }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dt_settings")
}

// Bloc 0 — Alertes techniques transverses (dérive coût, retard, surcharge équipe…)
model DtAlert {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type       DtAlertType
  severity   AlertSeverity
  title      String
  details    String?
  link       String?
  siteId     String?
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([tenantId, resolved])
  @@index([tenantId, type])
  @@map("dt_alerts")
}

enum DtAlertType {
  SITE_BUDGET_DEVIATION
  SITE_DELIVERY_DELAY
  MARGIN_BELOW_TARGET
  TEAM_CAPACITY_OVERLOAD
  MARKET_VALIDATION_PENDING
  HSE_INCIDENT
  QUALITY_NON_CONFORMITY
}

// Bloc 1 / fn 1.3 — Études et offres : pipeline AO
model Tender {
  id                 String      @id @default(cuid())
  tenantId           String
  tenant             Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference          String      @unique
  title              String
  moaName            String
  moaType            MoaType
  workType           WorkType
  estimatedBudget    BigInt
  submissionDeadline DateTime
  stage              TenderStage @default(OPPORTUNITY)
  probability        Int         @default(0) // 0-100
  studyCost          BigInt      @default(0)
  ourBidAmount       BigInt?
  ourMargin          Float?
  awarded            Boolean?
  awardedTo          String? // si attribué à un concurrent
  studyOwnerId       String
  studyOwner         User        @relation("TenderStudyOwner", fields: [studyOwnerId], references: [id])
  documents          String[]    @default([]) // URLs DCE / mémoire technique / etc.

  items TenderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, stage])
  @@index([tenantId, submissionDeadline])
  @@map("tenders")
}

enum TenderStage {
  OPPORTUNITY
  DCE_ANALYSIS
  SITE_VISIT
  TECHNICAL_STUDY
  PRICING
  SUBCONTRACTOR_QUOTES
  INTERNAL_VALIDATION
  SUBMITTED
  RESULTS_PENDING
  WON
  LOST
}

enum WorkType {
  BUILDING
  ROADWORK
  CIVIL_ENGINEERING
  HYDRAULIC
  LAYOUT
  INDUSTRIAL
  OTHER
}

// Bloc 1 / fn 1.3 — Articles BPU/DQE d'un AO
model TenderItem {
  id          String @id @default(cuid())
  tenderId    String
  tender      Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  code        String // BPU code (ex: 02.01.03)
  designation String
  unit        String // m³, m², ml, u, ...
  quantity    Float
  unitPrice   BigInt
  totalPrice  BigInt // calculé = quantity * unitPrice

  @@index([tenderId])
  @@map("tender_items")
}

// Bloc 1 / fn 1.3 — Concurrents observés (post-attribution)
model Competitor {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  stats    Json? // { totalParticipations, wins, avgGap, ... }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@map("competitors")
}

// Bloc 1 / fn 1.5 — Bibliothèque modes opératoires
model OperatingMethod {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       MethodCategory
  title          String
  version        String         @default("1.0")
  description    String?        @db.Text
  procedure      String         @db.Text // markdown
  attachments    String[]       @default([])
  authorId       String
  author         User           @relation("MethodAuthor", fields: [authorId], references: [id])
  status         MethodStatus   @default(ACTIVE)
  usageCount     Int            @default(0)
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, category])
  @@map("operating_methods")
}

enum MethodCategory {
  EARTHWORKS
  FOUNDATIONS
  STRUCTURE
  FORMWORK
  REBAR
  FINISHING
  ROADWORK
  HYDRAULIC
  SAFETY
  OTHER
}

enum MethodStatus {
  DRAFT
  ACTIVE
  OBSOLETE
  UNDER_REVIEW
}

// Bloc 1 / fn 1.5 — Plannings types
model TemplatePlanning {
  id            String @id @default(cuid())
  tenantId      String
  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteTypology  String // "R+8", "voirie urbaine 2 km", "AEP forage 50 m"
  totalDuration Int // jours
  phases        Json // [{ name, durationDays, dependencies }]
  authorId      String
  author        User   @relation("TemplatePlanningAuthor", fields: [authorId], references: [id])
  usageCount    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("template_plannings")
}

// Bloc 1 / fn 1.5 — Ratios de référence (h/m², kg/m³…)
model ReferenceRatio {
  id                String @id @default(cuid())
  tenantId          String
  tenant            Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workItem          String // "Ferraillage HA poteaux"
  unit              String // "kg/m³", "h/m²"
  refValue          Float
  observedValue     Float  @default(0)
  observationsCount Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, workItem])
  @@map("reference_ratios")
}

// Bloc 1 / fn 1.5 — Retours d'expérience post-chantier
model SiteRex {
  id              String   @id @default(cuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId        String
  author          User     @relation("RexAuthor", fields: [authorId], references: [id])
  issues          String   @db.Text
  solutions       String   @db.Text
  recommendations String   @db.Text
  keywords        String[] @default([])
  closedAt        DateTime

  createdAt DateTime @default(now())

  @@index([siteId])
  @@map("site_rex")
}

// Bloc 1 / fn 1.6 — Équipes ouvrières
model Crew {
  id                   String        @id @default(cuid())
  tenantId             String
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                 String // "GO Pont Mfoundi", "VRD Bonabéri"
  specialty            CrewSpecialty
  capacityHoursPerWeek Float         @default(40)
  leaderId             String?
  leader               User?         @relation("CrewLeader", fields: [leaderId], references: [id])
  active               Boolean       @default(true)

  assignments CrewAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("crews")
}

enum CrewSpecialty {
  CONCRETE
  FORMWORK
  REBAR
  FINISHING
  ROADWORK
  HYDRAULIC
  ELECTRICAL
  OTHER
}

// Bloc 1 / fn 1.6 — Affectations chantier × semaine
model CrewAssignment {
  id              String @id @default(cuid())
  crewId          String
  crew            Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)
  siteId          String
  site            Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  weekIso         String // "2026-W21"
  plannedHours    Float
  actualHours     Float?
  overloadPercent Float? // calculé si > 100

  createdAt DateTime @default(now())

  @@unique([crewId, siteId, weekIso])
  @@index([crewId, weekIso])
  @@map("crew_assignments")
}

// Bloc 1 / fn 1.7 — Évaluations sous-traitants (note 4 critères)
model SubcontractorEvaluation {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id])
  evaluatorId   String
  evaluator     User     @relation("SubEvaluator", fields: [evaluatorId], references: [id])
  qualityScore  Int // 1-5
  delayScore    Int // 1-5
  safetyScore   Int // 1-5
  behaviorScore Int // 1-5
  overallScore  Float // calculé = moyenne pondérée
  comments      String?  @db.Text

  createdAt DateTime @default(now())

  @@index([supplierId, createdAt])
  @@map("subcontractor_evaluations")
}

// Bloc 1 / fn 1.8 — Incidents et accidents HSE
model HseIncident {
  id                String           @id @default(cuid())
  siteId            String
  site              Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  occurredAt        DateTime
  type              IncidentType
  severity          IncidentSeverity
  victimsCount      Int              @default(0)
  workdaysLost      Int              @default(0)
  description       String           @db.Text
  immediateActions  String?          @db.Text
  rootCause         String?          @db.Text
  correctiveActions Json             @default("[]") // [{ action, owner, dueDate, done }]
  reportedById      String
  reportedBy        User             @relation("IncidentReporter", fields: [reportedById], references: [id])
  status            IncidentStatus   @default(OPEN)
  declaredCnps      Boolean          @default(false)
  declaredCnpsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, occurredAt])
  @@index([severity, status])
  @@map("hse_incidents")
}

enum IncidentType {
  NEAR_MISS
  MINOR_INJURY
  MAJOR_INJURY
  FATAL_ACCIDENT
  MATERIAL_DAMAGE
  ENVIRONMENT_INCIDENT
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  UNDER_INVESTIGATION
  ACTIONS_DEFINED
  ACTIONS_IN_PROGRESS
  CLOSED
}

// Bloc 1 / fn 1.8 — Audits chantiers
model SiteAudit {
  id          String        @id @default(cuid())
  siteId      String
  site        Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  auditType   AuditCategory
  scheduledAt DateTime
  completedAt DateTime?
  auditorId   String
  auditor     User          @relation("AuditAuditor", fields: [auditorId], references: [id])
  score       Float? // 0-100
  findings    Json          @default("[]") // [{ severity, description, recommendation }]
  reportUrl   String?

  createdAt DateTime @default(now())

  @@index([siteId, scheduledAt])
  @@map("site_audits")
}

enum AuditCategory {
  INTERNAL_QHSE
  EXTERNAL_ISO
  MOA_INSPECTION
  REGULATORY
}

// Bloc 1 / fn 1.8 — Non-conformités qualité / sécurité / environnement
model NonConformity {
  id               String      @id @default(cuid())
  siteId           String?
  site             Site?       @relation(fields: [siteId], references: [id])
  auditId          String?
  category         NcCategory
  criticality      Criticality
  description      String      @db.Text
  correctiveAction String?     @db.Text
  ownerId          String
  owner            User        @relation("NcOwner", fields: [ownerId], references: [id])
  dueDate          DateTime?
  status           NcStatus    @default(OPEN)
  closedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, status])
  @@map("non_conformities")
}

enum NcCategory {
  QUALITY
  SAFETY
  ENVIRONMENT
  REGULATORY
  DOCUMENTATION
}

enum Criticality {
  MINOR
  MAJOR
  CRITICAL
}

enum NcStatus {
  OPEN
  ACTION_PLANNED
  IN_PROGRESS
  CLOSED
  REJECTED
}

// Bloc 1 / fn 1.8 — Certifications ISO 9001 / 14001 / 45001
model Certification {
  id                    String    @id @default(cuid())
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  standard              String // "ISO 9001", "ISO 14001", "ISO 45001"
  scope                 String?
  issuedBy              String
  issuedAt              DateTime
  validUntil            DateTime
  surveillanceAuditDate DateTime?
  openNcCount           Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, standard])
  @@map("certifications")
}
