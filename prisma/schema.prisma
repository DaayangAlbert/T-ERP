  missingRequirements String[]  @default([])
  computedAt          DateTime  @default(now())
  dismissedAt         DateTime?

  @@unique([candidateId, jobOfferId])
  @@index([candidateId, score])
  @@map("job_matches")
}

// ========================================
// PORTAIL CANDIDAT — Profil détaillé (CAND fn 1.2)
