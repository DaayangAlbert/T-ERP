  updatedAt DateTime @updatedAt

  @@index([userId, fiscalYear])
  @@map("performance_bonuses")
}

enum BonusType {
  ANNUAL_RESULT
  OBJECTIVES
  SIGNING
  RETENTION
}

enum BonusStatus {
  TARGETED
  PROVISIONED
  VALIDATED
  PAID
}

// ========================================
// COMPTABLE — BLOC 0 : WORKFLOW PROMOTION RÔLES
// ========================================
// Permet à un RH de demander la promotion d'un utilisateur vers un rôle
// nécessitant validation (ACCOUNTANT, WORKS_DIRECTOR, etc.). La demande
// transite par 1..n validateurs (DAF + DT selon le rôle visé).
model RolePromotionRequest {
  id               String   @id @default(cuid())
  tenantId         String
  targetUserId     String
  targetUser       User     @relation("PromotionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  fromRole         Role
  toRole           Role
  requestedSiteIds String[] @default([])
  justification    String   @db.Text

  requestedById String
  requestedBy   User     @relation("PromotionRequester", fields: [requestedById], references: [id])
  requestedAt   DateTime @default(now())

  validatorRoles Role[] // ex: [DAF] ou [DAF, TECH_DIRECTOR]
  validations    Json   @default("[]") // [{ validatorId, validatorRole, validatedAt, decision, comment }]

  status     PromotionStatus @default(PENDING)
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([targetUserId])
  @@map("role_promotion_requests")
}

enum PromotionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// COMPTABLE — BLOC 1 fn 1.1/1.2 : ÉCRITURES COMPTABLES + PLAN SYSCOHADA
// ========================================
model Entry {
  id       String  @id @default(cuid())
  tenantId String
  siteId   String?
  site     Site?   @relation("EntrySite", fields: [siteId], references: [id])

  journalCode String // "ACH", "VTE", "BQ", "OD", "PAIE", "CAI"
  entryDate   DateTime
  reference   String
  description String

  status CptEntryStatus @default(DRAFT)

  createdById   String
  createdBy     User      @relation("EntryCreator", fields: [createdById], references: [id])
  validatedById String?
  validatedBy   User?     @relation("EntryValidator", fields: [validatedById], references: [id])
  validatedAt   DateTime?

  lines EntryLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, journalCode, reference])
  @@index([tenantId, journalCode, entryDate])
  @@index([siteId])
  @@map("cpt_entries")
}

enum CptEntryStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

model EntryLine {
  id      String @id @default(cuid())
  entryId String
  entry   Entry  @relation(fields: [entryId], references: [id], onDelete: Cascade)

  accountCode  String
  thirdPartyId String?
  description  String
  debit        BigInt  @default(0)
  credit       BigInt  @default(0)
  siteId       String?
  site         Site?   @relation("EntryLineSite", fields: [siteId], references: [id])
  lettering    String?

  createdAt DateTime @default(now())

  @@index([accountCode])
  @@index([entryId])
  @@index([siteId])
  @@map("cpt_entry_lines")
}

model ChartOfAccounts {
  id                 String      @id @default(cuid())
  tenantId           String
  code               String
  name               String
  class              Int // 1-9 SYSCOHADA
  type               AccountType
  requiresThirdParty Boolean     @default(false)
  active             Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, class])
  @@map("cpt_chart_of_accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  OFF_BALANCE
}

// ========================================
// COMPTABLE — BLOC 1 fn 1.3 : FACTURES FOURNISSEURS
// ========================================
model SupplierInvoice {
  id         String   @id @default(cuid())
  tenantId   String
