  workdaysLost      Int              @default(0)
  description       String           @db.Text
  immediateActions  String?          @db.Text
  rootCause         String?          @db.Text
  correctiveActions Json             @default("[]") // [{ action, owner, dueDate, done }]
  reportedById      String
  reportedBy        User             @relation("IncidentReporter", fields: [reportedById], references: [id])
