model Inventory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId      String?
  period      String // "2026-04"
  items       Json            @default("[]") // [{ code, label, theoretical, counted, gap }]
