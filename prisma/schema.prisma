// T-ERP — Schéma Prisma MVP
// Base PostgreSQL · multi-tenant par champ tenantId (sera évolué en schémas séparés en phase 2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// MULTI-TENANT : table globale des tenants
// ========================================

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique // batimcam, njoya, socabtp...
  name        String
  taxId       String?  // N° contribuable
  cnpsId      String?  // N° employeur CNPS
  plan        Plan     @default(STARTER)
  status      TenantStatus @default(ACTIVE)
  logoUrl     String?
  primaryColor String? @default("#A855F7")

  // Hiérarchie de groupe (Phase 2 / fn 1.2)
  // parentId pointe vers le tenant mère ; children est le côté inverse.
  // isGroup = true sur la société mère pour permettre l'agrégation consolidée.
  isGroup     Boolean  @default(false)
  parentId    String?
  parent      Tenant?  @relation("TenantGroup", fields: [parentId], references: [id])
  children    Tenant[] @relation("TenantGroup")
  sector      String?  // étiquette libre : "Bâtiment", "Routier", "Logistique"…

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  sites       Site[]
  jobOffers   JobOffer[]
  payslips    Payslip[]
  conversations Conversation[]
  documents   Document[]
  auditLogs   AuditLog[]
  objectives  Objective[]
  cashFlowProjections CashFlowProjection[]
  boardReports BoardReport[]
  validations Validation[]
  delegations Delegation[]
  reports     Report[]
  settings    TenantSettings?

  @@index([parentId])
  @@map("tenants")
}

enum Plan {
  STARTER
  STANDARD
  BUSINESS
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

// ========================================
// UTILISATEURS ET RÔLES
// ========================================

model User {
  id           String    @id @default(cuid())
  tenantId     String?   // null pour candidats externes et super-admin
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?

  // Si employé du tenant
  employeeId   String?   @unique // ex: EMP-2018-00001
  hireDate     DateTime?
  position     String?   // intitulé du poste
  category     String?   // catégorie pro (Cadre HC, ETAM, OQ, OS...)
  cnpsNumber   String?
  contractType ContractType?

  // Sécurité
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  emailVerified    Boolean @default(false)
  lastLoginAt      DateTime?

  // Rôle principal (MVP — rôles avancés en phase 2)
  role         Role     @default(EMPLOYEE)

  status       UserStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payslips     Payslip[]
  applications Application[]
  sentMessages Message[] @relation("SentMessages")
  conversationParticipants ConversationParticipant[]
  notifications Notification[]
  auditLogs    AuditLog[]
  managedSites Site[]   @relation("SiteManager")
  dgSettings   DgSettings?
  objectives   Objective[]
  boardReports BoardReport[]
  validationsInitiated  Validation[] @relation("ValidationInitiator")
  validationsAssigned   Validation[] @relation("ValidationCurrentApprover")
  validationsDecided    Validation[] @relation("ValidationDecidedBy")
  delegationsGiven      Delegation[] @relation("DelegationFrom")
  delegationsReceived   Delegation[] @relation("DelegationTo")
  reports               Report[]
  sessions              Session[]

  @@index([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

// ========================================
// OBJECTIFS DG (Phase 2 / fn 1.3)
// ========================================
// Objectifs annuels / trimestriels suivis par le DG.
model Objective {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  category    ObjectiveCategory
  title       String
  description String?  @db.Text

  targetValue Float
  actualValue Float    @default(0)
  unit        String   // "FCFA", "%", "jours", "unités", "M FCFA", etc.

  period      ObjectivePeriod
  year        Int
  quarter     Int?     // 1..4 si period = QUARTERLY ou MONTHLY ; null si ANNUAL
  weight      Int      @default(1) // pondération sur la note globale

  status      ObjectiveStatus @default(IN_PROGRESS)
  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, year, period])
  @@index([ownerId, year])
  @@map("objectives")
}

enum ObjectiveCategory {
  FINANCIAL
  COMMERCIAL
  HR
  HSE
  STRATEGIC
}

enum ObjectivePeriod {
  ANNUAL
  QUARTERLY
  MONTHLY
}

enum ObjectiveStatus {
  IN_PROGRESS
  AT_RISK
  ACHIEVED
  MISSED
  CANCELLED
}

// ========================================
// REPORTING CONSEIL D'ADMINISTRATION (Phase 2 / fn 1.5)
// ========================================
// Rapports CA générés par le DG (mensuel, trimestriel, annuel,
// extraordinaire). Le contenu (KPIs agrégés, chantiers, RH…) est
// matérialisé au moment de la génération via lib/board-report-generator.
model BoardReport {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  type        BoardReportType
  period      String   // "2026-04", "2026-T1", "2026"
  boardDate   DateTime

  chapters    Json     // { financial: true, operational: true, ... }
  comments    Json     // { financial: "...", operational: "...", ... }
  data        Json     // snapshot des KPIs au moment de la génération

  pdfUrl      String?
  status      BoardReportStatus @default(DRAFT)
  sentTo      Json?    // [{ email, name, sentAt }]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, type, period])
  @@index([tenantId, status])
  @@map("board_reports")
}

enum BoardReportType {
  MONTHLY
  QUARTERLY
  ANNUAL
  EXTRAORDINARY
}

enum BoardReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
}

// ========================================
// TRÉSORERIE PRÉVISIONNELLE DG (Phase 2 / fn 1.4)
// ========================================
// Projections de flux de trésorerie sur les semaines à venir, alimentées
// soit automatiquement (factures, BC, paie, fiscalité) soit manuellement.
model CashFlowProjection {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type          CashFlowType
  category      String   // CLIENT_PAYMENT, SUPPLIER, SALARY, TAX_VAT, TAX_CNPS, TAX_IRPP, OTHER
  label         String
  amount        BigInt   // toujours positif ; le signe est porté par `type`
  expectedDate  DateTime
  probability   Int      @default(100) // 0..100, pondération de la prévision

  sourceType    String?  // INVOICE | PURCHASE_ORDER | PAYROLL | TAX | MANUAL
  sourceId      String?

  realized      Boolean  @default(false)
  realizedDate  DateTime?
  realizedAmount BigInt?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, expectedDate])
  @@index([tenantId, type, expectedDate])
  @@map("cashflow_projections")
}

enum CashFlowType {
  INCOME
  EXPENSE
}

// ========================================
// PRÉFÉRENCES DG (Phase 2 — Bloc 1)
// ========================================
// Stocke les préférences de l'espace DG (1 ligne par utilisateur DG).
// Les champs métier seront ajoutés au fil des fonctions livrées.
model DgSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dg_settings")
}

enum Role {
  // Direction
  DG               // Directeur Général
  DAF              // Directeur Administratif et Financier
  SG               // Secrétaire Générale
  HR               // Responsable RH

  // Production
  TECH_DIRECTOR    // Directeur technique
  WORKS_DIRECTOR   // Directeur de travaux (projet)
  WORKS_MANAGER    // Conducteur de travaux
  SITE_MANAGER     // Chef de chantier
  WORKER           // Ouvrier

  // Support
  ACCOUNTANT
  LOGISTICS
  WAREHOUSE        // Magasinier
  GED              // Gestionnaire documentaire
  EMPLOYEE         // Employé bureau

  // Externe
  CANDIDATE        // Candidat portail emploi

  // Admin
  TENANT_ADMIN     // Informaticien d'entreprise
  SUPER_ADMIN      // Anthropic-style super-admin SaaS
}

enum ContractType {
  CDI
  CDD
  STAGE
  JOURNALIER
  PRESTATAIRE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ========================================
// CHANTIERS
// ========================================

model Site {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code         String   // CHT-2025-031
  name         String   // Pont Mfoundi
  client       String   // Commune Yaoundé I
  type         SiteType
  region       String?  // Yaoundé, Douala, Bafoussam...

  budget       BigInt   // FCFA
  startDate    DateTime
  plannedEndDate DateTime
  actualEndDate  DateTime?

  progress     Int      @default(0) // 0-100
  margin       Float    @default(0) // pourcentage
  status       SiteStatus @default(PLANNED)

  managerId    String?  // directeur de travaux
  manager      User?    @relation("SiteManager", fields: [managerId], references: [id])

  // Géoloc pour la vue carte (Phase 2 / Bloc 3 — fn 3.1)
  lat          Float?
  lng          Float?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract     SiteContract?
  photos       SitePhoto[]
  alerts       SiteAlert[]
  decisions    SiteDecision[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("sites")
}

enum SiteType {
  ROAD            // BTP routier
  BUILDING        // Bâtiment
  CIVIL_ENG       // Génie civil
  DEVELOPMENT     // Aménagement
  HYDRAULIC       // Forage / AEP
}

enum SiteStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  AT_RISK         // Vigilance
  DRIFTING        // Dérive
  COMPLETED
  ARCHIVED
}

// ========================================
// PAIE
// ========================================

model Payslip {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  period        DateTime // 1er du mois (ex: 2025-09-01)
  paymentDate   DateTime
  paymentMode   String   @default("VIREMENT") // VIREMENT, ESPECES, CHEQUE, MOMO

  // Totaux pré-calculés (calcul détaillé en phase 2)
  grossAmount   BigInt   // Brut
  taxableGross  BigInt   // Brut imposable
  netAmount     BigInt   // Net à payer
  socialCharges BigInt   @default(0)
  fiscalCharges BigInt   @default(0)
  employerCharges BigInt @default(0)

  status        PayslipStatus @default(DRAFT)

  // Workflow validation
  validatedN1At DateTime?
  validatedN2At DateTime?
  validatedN3At DateTime?
  paidAt        DateTime?

  pdfUrl        String?

  lines         PayslipLine[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId, period])
  @@index([tenantId, period])
  @@map("payslips")
}

enum PayslipStatus {
  DRAFT
  CALCULATED
  VALIDATED_N1     // RH
  VALIDATED_N2     // DAF
  VALIDATED_N3     // DG
  PAID
  CANCELLED
}

model PayslipLine {
  id        String  @id @default(cuid())
  payslipId String
  payslip   Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  code      String  // A001, A045, A050, A056-A072
  label     String  // "Salaire de base", "IRPP", etc.
  quantity  Float?  // 30 (jours)
  base      BigInt? // 6667
  rate      Float?  // 4.20 pour CNPS
  amountPlus  BigInt? // colonne MONTANT+
  amountMinus BigInt? // colonne MONTANT-
  employerAmount BigInt? // RET PATRON

  order     Int     @default(0)

  @@index([payslipId])
  @@map("payslip_lines")
}

// ========================================
// PORTAIL EMPLOI
// ========================================

model JobOffer {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  reference     String   // REC-2026-008
  title         String   // Ingénieur travaux BTP
  department    String?  // Direction Technique
  contractType  ContractType
  category      String   // Cadre, ETAM, OQ...
  positions     Int      @default(1)

  description   String   @db.Text
  requirements  String   @db.Text

  salaryMin     BigInt?
  salaryMax     BigInt?

  region        String?
  publishedAt   DateTime?
  expiresAt     DateTime?
  status        JobStatus @default(DRAFT)

  applications  Application[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([status, publishedAt])
  @@map("job_offers")
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model Application {
  id          String   @id @default(cuid())
  jobOfferId  String
  jobOffer    JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  userId      String   // candidat (User avec role=CANDIDATE)
  user        User     @relation(fields: [userId], references: [id])

  cvUrl       String?
  coverLetter String?  @db.Text
  score       Int?     // 0-100, calculé par tri auto
  stage       AppStage @default(RECEIVED)
  notes       String?  @db.Text

  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobOfferId, userId])
  @@map("applications")
}

enum AppStage {
  RECEIVED
  SHORTLISTED
  INTERVIEW
  TECHNICAL_TEST
  OFFER
  HIRED
  REJECTED
}

// ========================================
// MESSAGERIE
// ========================================

model Conversation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String?  // null pour DM, défini pour groupes
  isGroup     Boolean  @default(false)
  avatarUrl   String?

  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages    Message[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?
  isPinned       Boolean  @default(false)
  isMuted        Boolean  @default(false)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User     @relation("SentMessages", fields: [senderId], references: [id])

  content         String   @db.Text
  attachmentUrl   String?
  attachmentName  String?
  attachmentSize  Int?

  isSystem        Boolean  @default(false) // messages système type "X a partagé un document"

  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ========================================
// GED
// ========================================

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  category    String?  // Marché, Plan, Décompte, PV, Photo...
  folder      String?  // chemin virtuel
  mimeType    String
  sizeBytes   BigInt
  url         String   // URL stockage (S3 ou local)

  // Liens contextuels (optionnels)
  siteId      String?
  authorId    String

  // OCR (phase 2)
  ocrContent  String?  @db.Text

  status      DocStatus @default(DRAFT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, folder])
  @@index([tenantId, siteId])
  @@map("documents")
}

enum DocStatus {
  DRAFT
  PUBLISHED
  SIGNED
  ARCHIVED
}

// ========================================
// NOTIFICATIONS
// ========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // payslip_ready, validation_required, message_received...
  title     String
  body      String?
  link      String?  // chemin app à ouvrir

  read      Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ========================================
// AUDIT TRAIL
// ========================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  action      String   // user.login, payslip.validate, site.update...
  entityType  String?
  entityId    String?
  metadata    Json?    // données contextuelles (avant/après, IP, user-agent...)

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ========================================
// VALIDATIONS DG (Phase 2 / Bloc 2 — fn 2.1)
// ========================================
// Demandes nécessitant l'approbation d'un cadre (paie, dépense, achat,
// embauche, marché, congé). Chaque demande porte un workflow JSON avec
// les étapes (initiateur → N1 → N2 → N3) et leurs dates de validation.
model Validation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type            ValidationType
  reference       String   // VAL-2026-0042
  title           String
  description     String?  @db.Text
  amount          BigInt?  // FCFA si applicable

  initiatorId     String
  initiator       User     @relation("ValidationInitiator", fields: [initiatorId], references: [id])

  // Étape courante du workflow (par convention : "RH" | "DAF" | "DG")
  currentStep     String?
  currentApproverId String?
  currentApprover User?    @relation("ValidationCurrentApprover", fields: [currentApproverId], references: [id])

  // Workflow complet (étapes + dates) — { steps: [{ key, label, role, status, decidedBy?, decidedAt? }] }
  workflow        Json
  // Historique commentaires + demandes justification + délégations
  comments        Json     @default("[]")

  status          ValidationStatus @default(PENDING)
  priority        ValidationPriority @default(NORMAL)

  decidedById     String?
  decidedBy       User?    @relation("ValidationDecidedBy", fields: [decidedById], references: [id])
  decisionAt      DateTime?
  decisionReason  String?  @db.Text

  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([currentApproverId, status])
  @@index([tenantId, type, status])
  @@map("validations")
}

enum ValidationType {
  PAYROLL
  EXPENSE
  PURCHASE
  HIRING
  CONTRACT
  LEAVE
  OTHER
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum ValidationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Délégations ponctuelles ou permanentes : un cadre délègue ses pouvoirs
// d'approbation à un autre, pour certains types et jusqu'à un montant max.
model Delegation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fromUserId  String
  fromUser    User     @relation("DelegationFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User     @relation("DelegationTo", fields: [toUserId], references: [id])

  types       ValidationType[]
  maxAmount   BigInt?
  startDate   DateTime
  endDate     DateTime?
  active      Boolean  @default(true)
  reason      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, active])
  @@index([fromUserId, active])
  @@map("delegations")
}

// ========================================
// RAPPORTS CONSOLIDÉS DG (Phase 2 / Bloc 2 — fn 2.2)
// ========================================
// Rapports stratégiques générés par le DG : synthèse exécutive, tableau
// de bord mensuel, bilan annuel, note trimestrielle, rapport sur-mesure.
// Le wizard permet de configurer les blocs (KPIs, graphes, tableaux) et
// d'envoyer le rapport par email aux destinataires.
model Report {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])

  type          ReportType
  title         String
  period        String   // "S18-2026", "2026-04", "2026-T1"...
  parameters    Json     // { scope, start, end, ... }
  blocks        Json     // [{ type, label, ... }] — bibliothèque de blocs
  data          Json     // snapshot des données calculées au moment de la génération
  pdfUrl        String?
  status        ReportStatus @default(GENERATED)
  scheduledRule String?  // cron-like si rapport planifié
  recipients    Json?    // [{ email, name, sentAt }]
  generatedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("reports")
}

enum ReportType {
  EXECUTIVE_SUMMARY     // Synthèse exécutive hebdo
  MONTHLY_DASHBOARD     // Tableau de bord stratégique mensuel
  ANNUAL_GROUP          // Bilan annuel groupe
  QUARTERLY_NOTE        // Note d'activité trimestrielle
  CUSTOM                // Sur-mesure
}

enum ReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

// ========================================
// CONFIGURATION TENANT (Phase 2 / Bloc 2 — fn 2.3)
// ========================================
// Paramétrage du tenant par le DG : identité, modules actifs, plan
// comptable, paramètres paie, workflows de validation, notifications,
// intégrations API. Une seule ligne par tenant.
model TenantSettings {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  identity      Json     // raison sociale, NIU, RCCM, capital, sièges, représentants
  modules       Json     // { msg: true, payroll: true, ... }
  payrollRates  Json     // barèmes IRPP + taux CNPS/CFC/FNE/RAV/TC/CAC/CFS
  workflows     Json     // règles de validation par type
  notifications Json     // matrice destinataires × événements × canaux
  integrations  Json     // clés API (chiffrées) — banques, CNPS, MoMo, Resend

  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@map("tenant_settings")
}

// ========================================
// SESSIONS UTILISATEUR (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Sessions actives suivies pour permettre au DG de voir qui est connecté
// et déconnecter à distance. Une session ≠ un JWT : c'est une trace
// d'identification (IP, user-agent, géoloc).
model Session {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress       String?
  userAgent       String?
  location        String?  // résolu via API IP geolocation
  suspicious      Boolean  @default(false)
  lastActivityAt  DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([userId, expiresAt])
  @@map("sessions")
}

// ========================================
// RÔLES PERSONNALISÉS (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Permet de cloner un rôle système et d'ajuster ses permissions pour un
// tenant donné (ex: "Validateur dérogatoire", "Auditeur externe").
model CustomRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  basedOn     Role
  permissions Json     // { sites: ["read"], payroll: ["read", "write"], ... }
  userCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("custom_roles")
}

// ========================================
// CHANTIERS — VUE DG TRANSVERSE (Phase 2 / Bloc 3 — fn 3.1)
// ========================================
// Contrats de marché (initialAmount + avenants), photos chantier,
// alertes (dérives budget, retards, HSE) et décisions DG enregistrées.
model SiteContract {
  id              String   @id @default(cuid())
  siteId          String   @unique
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  reference       String
  initialAmount   BigInt
  currentAmount   BigInt
  amendments      Json     @default("[]") // [{ ref, amount, date, reason, validatedBy }]
  guarantees      Json     @default("{}") // { caution, retention, penalties }
  paymentTerms    String?
  publicMarket    Boolean  @default(false)
  procuringEntity String?  // MINTP, MINHDU, FEICOM...
  signedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("site_contracts")
}

model SitePhoto {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url         String
  caption     String?
  takenAt     DateTime
  uploadedBy  String

  createdAt   DateTime @default(now())

  @@index([siteId, takenAt])
  @@map("site_photos")
}

model SiteAlert {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  severity  AlertSeverity
  type      String   // BUDGET_OVERRUN, DELAY, HSE_INCIDENT, MARGIN_DROP, ...
  message   String
  resolved  Boolean  @default(false)
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  @@index([siteId, resolved])
  @@map("site_alerts")
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SiteDecision {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@map("site_decisions")
}
