// ════════════════════════════════════════════════════════════════════════
// RH — Historique des révisions salariales (RH 1.2 — extension)
// ════════════════════════════════════════════════════════════════════════
// Trace chaque modification du salaire de base d'un collaborateur :
// embauche initiale, augmentation annuelle, promotion, ajustement
// négocié. Le `User.baseSalary` reflète toujours la dernière entrée.
model SalaryHistory {
  id           String             @id @default(cuid())
  tenantId     String
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Période d'effet (1er du mois). Permet d'aligner la rétroactivité paie.
  effectiveAt  DateTime
  // Montant en FCFA. Si baseSalary null → catégorie (cas embauche initiale
  // avant définition explicite). Sinon montant figé pour traçabilité.
  baseSalary   BigInt
  previousBase BigInt? // pour calculer la variation
  reason       SalaryChangeReason
  notes        String?            @db.Text
  decidedById  String? // userId du décideur (RH/DG)
  // Audit
  createdAt    DateTime           @default(now())

  @@index([tenantId, userId, effectiveAt])
  @@map("salary_history")
}

enum SalaryChangeReason {
  HIRING // Embauche initiale
  ANNUAL_REVIEW // Révision annuelle
  PROMOTION // Promotion
  NEGOTIATION // Renégociation contractuelle
  CCM_ADJUSTMENT // Ajustement Convention Collective
  CORRECTION // Correction d'erreur
  OTHER
}

// ════════════════════════════════════════════════════════════════════════
// RH — Contrats de travail générés en ligne (RH 1.3)
// ════════════════════════════════════════════════════════════════════════
// Permet à un agent RH de rédiger, générer (PDF), signer électroniquement
// et archiver un contrat de travail directement depuis la fiche du
// collaborateur, sans passer par Word. Cinq templates couvrant les besoins
// BTP Cameroun : CDI, CDD, Stage, Journalier, Prestataire.
//
// Workflow :
//   1. RH ouvre wizard depuis fiche personnel → choisit type
//   2. Formulaire pré-rempli avec données collaborateur + saisie clauses
//   3. Génération PDF (DRAFT) → prévisualisation
//   4. Signature électronique simple (nom employeur + checkbox + horodatage)
//      L'employé peut signer plus tard via son espace personnel.
//   5. SIGNED → archivage auto dans EmployeeDocument type CONTRACT
model EmploymentContract {
  id               String  @id @default(cuid())
  tenantId         String
  // Salarié concerné
  userId           String
  user             User    @relation("EmploymentContractEmployee", fields: [userId], references: [id], onDelete: Cascade)
  // Rédacteur (typiquement RH)
  draftedById      String
  draftedBy        User    @relation("EmploymentContractDrafter", fields: [draftedById], references: [id])
  // Signataire côté employeur (RH/DG)
  employerSignerId String?
  employerSigner   User?   @relation("EmploymentContractEmployerSigner", fields: [employerSignerId], references: [id])

  reference String // ex "CDI-2026-031"
  type      ContractType
  status    EmploymentContractStatus @default(DRAFT)

  // Termes contractuels
  jobTitle             String
  professionalCategory String? // CCT BTP : Cadre HC, ETAM N3, OQ N4...
  baseSalary           BigInt
  trialPeriodDays      Int?      @default(0)
  startDate            DateTime
  endDate              DateTime? // CDD/STAGE/JOURNALIER
  workLocation         String? // adresse / chantier
  workingHours         String?   @default("173 h/mois")

  // Avantages et clauses (JSON libre pour souplesse)
  benefits      Json    @default("[]") // ["Logement", "Transport", "Communication"]
  customClauses Json    @default("[]") // [{ title, body }]
  pdfUrl        String? // URL du PDF généré (R2 ou local)

  // Signature
  employerSignedAt      DateTime?
  employerSignatureText String? // ex "Jean DUPONT, DG"
  employeeSignedAt      DateTime?
  employeeSignatureText String?
  // Document archivé après signature complète
  archivedDocumentId    String?

  // Termes spécifiques par type
  internshipSchool    String? // STAGE — école d'origine
  internshipTutor     String? // STAGE — tuteur
  providerCompanyName String? // PRESTATAIRE
  providerRccm        String? // PRESTATAIRE
  providerNiu         String? // PRESTATAIRE
  dailyRate           BigInt? // JOURNALIER — taux journalier
  cdiMotive           String? // CDD — motif légal du recours au CDD

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("employment_contracts")
}

enum EmploymentContractStatus {
  DRAFT // En rédaction
  PENDING_SIGNATURE // Généré PDF, en attente de signature employeur
  SIGNED // Signé côté employeur ET employé
  ACTIVE // Contrat en vigueur (= SIGNED + startDate atteint)
  TERMINATED // Résilié / arrivé à terme
  CANCELLED // Annulé avant signature
}

model RhAlert {
  id        String        @id @default(cuid())
  tenantId  String
  type      RhAlertType
  severity  AlertSeverity
  title     String
  details   String?
  link      String?
  resolved  Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([tenantId, resolved])
  @@map("rh_alerts")
}

enum RhAlertType {
  MEDICAL_VISIT_DUE
  TRAINING_RECYCLE_DUE
  CDD_ENDING
  LEAVE_REQUEST_PENDING
  PAYROLL_INPUT_DEADLINE
}

model RhSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertsConfig    Json? // { medicalVisitDaysBefore, trainingRecycleDaysBefore, cddEndingDaysBefore, channels[] }
  signatureConfig Json? // { authorizedDocs[], delegates[] } — RH Bloc 2 / fn 2.3
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("rh_settings")
}

model UserSignaturePower {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  soloLimit       BigInt   @default(5000000) // FCFA — plafond signature seul
  coSignLimit     BigInt   @default(50000000) // FCFA — plafond cosignature
  coSigners       String[] @default([]) // userIds des cosignataires
  banksRegistered String[] @default([]) // codes banques où la signature est déposée (UBA, BICEC, AFRILAND, ECOBANK, SGBC)
  proxyHolders    Json     @default("[]") // [{ id, toUserId, name, position, scope, maxAmount, startDate, endDate, active }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_signature_powers")
}

// ========================================
// GED
// ========================================

model Document {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  category  String? // Marché, Plan, Décompte, PV, Photo...
  folder    String? // chemin virtuel
  mimeType  String
  sizeBytes BigInt
  url       String // URL stockage (S3 ou local)

  // Liens contextuels (optionnels)
  siteId   String?
  authorId String

  // OCR (phase 2)
  ocrContent String? @db.Text

  status DocStatus @default(DRAFT)

  // GED — Référent documentaire (Bloc 0)
  spaceId           String?
  space             DocumentSpace?             @relation(fields: [spaceId], references: [id])
  classificationId  String?
  classification    DocumentClassification?    @relation(fields: [classificationId], references: [id])
  internalReference String?                    @unique // ex: "PEX-2026-0142"
  confidentiality   Confidentiality            @default(INTERNAL)
  workflowInstances DocumentWorkflowInstance[]
  retentionRecord   DocumentRetentionRecord?
  accessRequests    DocumentAccessRequest[]
  gedAuditEvents    GedAuditEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, folder])
  @@index([tenantId, siteId])
  @@index([tenantId, spaceId])
  @@index([tenantId, classificationId])
