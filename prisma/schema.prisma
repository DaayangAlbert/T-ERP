// T-ERP — Schéma Prisma MVP
// Base PostgreSQL · multi-tenant par champ tenantId (sera évolué en schémas séparés en phase 2)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// MULTI-TENANT : table globale des tenants
// ========================================

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique // batimcam, njoya, socabtp...
  name        String
  taxId       String?  // N° contribuable
  cnpsId      String?  // N° employeur CNPS
  plan        Plan     @default(STARTER)
  status      TenantStatus @default(ACTIVE)
  logoUrl     String?
  primaryColor String? @default("#A855F7")

  // Hiérarchie de groupe (Phase 2 / fn 1.2)
  // parentId pointe vers le tenant mère ; children est le côté inverse.
  // isGroup = true sur la société mère pour permettre l'agrégation consolidée.
  isGroup     Boolean  @default(false)
  parentId    String?
  parent      Tenant?  @relation("TenantGroup", fields: [parentId], references: [id])
  children    Tenant[] @relation("TenantGroup")
  sector      String?  // étiquette libre : "Bâtiment", "Routier", "Logistique"…

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  sites       Site[]
  jobOffers   JobOffer[]
  payslips    Payslip[]
  conversations Conversation[]
  documents   Document[]
  auditLogs   AuditLog[]
  objectives  Objective[]
  cashFlowProjections CashFlowProjection[]
  boardReports BoardReport[]
  validations Validation[]
  delegations Delegation[]
  reports     Report[]
  settings    TenantSettings?
  milestones  Milestone[]
  resourceConflicts ResourceConflict[]
  successionPlans SuccessionPlan[]
  trainings   Training[]
  socialIndicators SocialIndicator[]
  financialPeriods FinancialPeriod[]
  financialCommitments FinancialCommitment[]
  bankAccounts BankAccount[]
  accountingPeriods AccountingPeriod[]
  accountingEntries AccountingEntry[]
  annualClosures AnnualClosure[]
  suppliers   Supplier[]
  frameworkContracts FrameworkContract[]
  purchaseOrders PurchaseOrder[]
  fixedAssets FixedAsset[]
  stockMovements StockMovement[]
  inventories Inventory[]
  losses      Loss[]

  @@index([parentId])
  @@map("tenants")
}

enum Plan {
  STARTER
  STANDARD
  BUSINESS
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  ARCHIVED
}

// ========================================
// UTILISATEURS ET RÔLES
// ========================================

model User {
  id           String    @id @default(cuid())
  tenantId     String?   // null pour candidats externes et super-admin
  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?

  // Si employé du tenant
  employeeId   String?   @unique // ex: EMP-2018-00001
  hireDate     DateTime?
  position     String?   // intitulé du poste
  category     String?   // catégorie pro (Cadre HC, ETAM, OQ, OS...)
  cnpsNumber   String?
  contractType ContractType?

  // Sécurité
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  emailVerified    Boolean @default(false)
  lastLoginAt      DateTime?

  // Rôle principal (MVP — rôles avancés en phase 2)
  role         Role     @default(EMPLOYEE)

  status       UserStatus @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payslips     Payslip[]
  applications Application[]
  sentMessages Message[] @relation("SentMessages")
  conversationParticipants ConversationParticipant[]
  notifications Notification[]
  auditLogs    AuditLog[]
  managedSites Site[]   @relation("SiteManager")
  dgSettings   DgSettings?
  objectives   Objective[]
  boardReports BoardReport[]
  validationsInitiated  Validation[] @relation("ValidationInitiator")
  validationsAssigned   Validation[] @relation("ValidationCurrentApprover")
  validationsDecided    Validation[] @relation("ValidationDecidedBy")
  delegationsGiven      Delegation[] @relation("DelegationFrom")
  delegationsReceived   Delegation[] @relation("DelegationTo")
  reports               Report[]
  sessions              Session[]
  trainings             Training[]
  successionsAsIncumbent SuccessionPlan[] @relation("SuccessionIncumbent")
  successionsAsSuccessor SuccessionPlan[] @relation("SuccessionSuccessor")
  preferences           UserPreferences?
  signature             UserSignature?
  agendaEvents          AgendaEvent[]
  interestDeclarations  InterestDeclaration[]
  benefits              BenefitInKind[]
  performanceBonuses    PerformanceBonus[]
  dafSettings           DafSettings?

  @@index([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

// ========================================
// OBJECTIFS DG (Phase 2 / fn 1.3)
// ========================================
// Objectifs annuels / trimestriels suivis par le DG.
model Objective {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  category    ObjectiveCategory
  title       String
  description String?  @db.Text

  targetValue Float
  actualValue Float    @default(0)
  unit        String   // "FCFA", "%", "jours", "unités", "M FCFA", etc.

  period      ObjectivePeriod
  year        Int
  quarter     Int?     // 1..4 si period = QUARTERLY ou MONTHLY ; null si ANNUAL
  weight      Int      @default(1) // pondération sur la note globale

  status      ObjectiveStatus @default(IN_PROGRESS)
  startDate   DateTime
  endDate     DateTime

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, year, period])
  @@index([ownerId, year])
  @@map("objectives")
}

enum ObjectiveCategory {
  FINANCIAL
  COMMERCIAL
  HR
  HSE
  STRATEGIC
}

enum ObjectivePeriod {
  ANNUAL
  QUARTERLY
  MONTHLY
}

enum ObjectiveStatus {
  IN_PROGRESS
  AT_RISK
  ACHIEVED
  MISSED
  CANCELLED
}

// ========================================
// REPORTING CONSEIL D'ADMINISTRATION (Phase 2 / fn 1.5)
// ========================================
// Rapports CA générés par le DG (mensuel, trimestriel, annuel,
// extraordinaire). Le contenu (KPIs agrégés, chantiers, RH…) est
// matérialisé au moment de la génération via lib/board-report-generator.
model BoardReport {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  type        BoardReportType
  period      String   // "2026-04", "2026-T1", "2026"
  boardDate   DateTime

  chapters    Json     // { financial: true, operational: true, ... }
  comments    Json     // { financial: "...", operational: "...", ... }
  data        Json     // snapshot des KPIs au moment de la génération

  pdfUrl      String?
  status      BoardReportStatus @default(DRAFT)
  sentTo      Json?    // [{ email, name, sentAt }]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, type, period])
  @@index([tenantId, status])
  @@map("board_reports")
}

enum BoardReportType {
  MONTHLY
  QUARTERLY
  ANNUAL
  EXTRAORDINARY
}

enum BoardReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
}

// ========================================
// TRÉSORERIE PRÉVISIONNELLE DG (Phase 2 / fn 1.4)
// ========================================
// Projections de flux de trésorerie sur les semaines à venir, alimentées
// soit automatiquement (factures, BC, paie, fiscalité) soit manuellement.
model CashFlowProjection {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type          CashFlowType
  category      String   // CLIENT_PAYMENT, SUPPLIER, SALARY, TAX_VAT, TAX_CNPS, TAX_IRPP, OTHER
  label         String
  amount        BigInt   // toujours positif ; le signe est porté par `type`
  expectedDate  DateTime
  probability   Int      @default(100) // 0..100, pondération de la prévision

  sourceType    String?  // INVOICE | PURCHASE_ORDER | PAYROLL | TAX | MANUAL
  sourceId      String?

  realized      Boolean  @default(false)
  realizedDate  DateTime?
  realizedAmount BigInt?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, expectedDate])
  @@index([tenantId, type, expectedDate])
  @@map("cashflow_projections")
}

enum CashFlowType {
  INCOME
  EXPENSE
}

// ========================================
// PRÉFÉRENCES DG (Phase 2 — Bloc 1)
// ========================================
// Stocke les préférences de l'espace DG (1 ligne par utilisateur DG).
// Les champs métier seront ajoutés au fil des fonctions livrées.
model DgSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dg_settings")
}

enum Role {
  // Direction
  DG               // Directeur Général
  DAF              // Directeur Administratif et Financier
  SG               // Secrétaire Générale
  HR               // Responsable RH

  // Production
  TECH_DIRECTOR    // Directeur technique
  WORKS_DIRECTOR   // Directeur de travaux (projet)
  WORKS_MANAGER    // Conducteur de travaux
  SITE_MANAGER     // Chef de chantier
  WORKER           // Ouvrier

  // Support
  ACCOUNTANT
  LOGISTICS
  WAREHOUSE        // Magasinier
  GED              // Gestionnaire documentaire
  EMPLOYEE         // Employé bureau

  // Externe
  CANDIDATE        // Candidat portail emploi

  // Admin
  TENANT_ADMIN     // Informaticien d'entreprise
  SUPER_ADMIN      // Anthropic-style super-admin SaaS
}

enum ContractType {
  CDI
  CDD
  STAGE
  JOURNALIER
  PRESTATAIRE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ========================================
// CHANTIERS
// ========================================

model Site {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code         String   // CHT-2025-031
  name         String   // Pont Mfoundi
  client       String   // Commune Yaoundé I
  type         SiteType
  region       String?  // Yaoundé, Douala, Bafoussam...

  budget       BigInt   // FCFA
  startDate    DateTime
  plannedEndDate DateTime
  actualEndDate  DateTime?

  progress     Int      @default(0) // 0-100
  margin       Float    @default(0) // pourcentage
  status       SiteStatus @default(PLANNED)

  managerId    String?  // directeur de travaux
  manager      User?    @relation("SiteManager", fields: [managerId], references: [id])

  // Géoloc pour la vue carte (Phase 2 / Bloc 3 — fn 3.1)
  lat          Float?
  lng          Float?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract     SiteContract?
  photos       SitePhoto[]
  alerts       SiteAlert[]
  decisions    SiteDecision[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("sites")
}

enum SiteType {
  ROAD            // BTP routier
  BUILDING        // Bâtiment
  CIVIL_ENG       // Génie civil
  DEVELOPMENT     // Aménagement
  HYDRAULIC       // Forage / AEP
}

enum SiteStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  AT_RISK         // Vigilance
  DRIFTING        // Dérive
  COMPLETED
  ARCHIVED
}

// ========================================
// PAIE
// ========================================

model Payslip {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  period        DateTime // 1er du mois (ex: 2025-09-01)
  paymentDate   DateTime
  paymentMode   String   @default("VIREMENT") // VIREMENT, ESPECES, CHEQUE, MOMO

  // Totaux pré-calculés (calcul détaillé en phase 2)
  grossAmount   BigInt   // Brut
  taxableGross  BigInt   // Brut imposable
  netAmount     BigInt   // Net à payer
  socialCharges BigInt   @default(0)
  fiscalCharges BigInt   @default(0)
  employerCharges BigInt @default(0)

  status        PayslipStatus @default(DRAFT)

  // Workflow validation
  validatedN1At DateTime?
  validatedN2At DateTime?
  validatedN3At DateTime?
  paidAt        DateTime?

  pdfUrl        String?

  lines         PayslipLine[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, userId, period])
  @@index([tenantId, period])
  @@map("payslips")
}

enum PayslipStatus {
  DRAFT
  CALCULATED
  VALIDATED_N1     // RH
  VALIDATED_N2     // DAF
  VALIDATED_N3     // DG
  PAID
  CANCELLED
}

model PayslipLine {
  id        String  @id @default(cuid())
  payslipId String
  payslip   Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  code      String  // A001, A045, A050, A056-A072
  label     String  // "Salaire de base", "IRPP", etc.
  quantity  Float?  // 30 (jours)
  base      BigInt? // 6667
  rate      Float?  // 4.20 pour CNPS
  amountPlus  BigInt? // colonne MONTANT+
  amountMinus BigInt? // colonne MONTANT-
  employerAmount BigInt? // RET PATRON

  order     Int     @default(0)

  @@index([payslipId])
  @@map("payslip_lines")
}

// ========================================
// PORTAIL EMPLOI
// ========================================

model JobOffer {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  reference     String   // REC-2026-008
  title         String   // Ingénieur travaux BTP
  department    String?  // Direction Technique
  contractType  ContractType
  category      String   // Cadre, ETAM, OQ...
  positions     Int      @default(1)

  description   String   @db.Text
  requirements  String   @db.Text

  salaryMin     BigInt?
  salaryMax     BigInt?

  region        String?
  publishedAt   DateTime?
  expiresAt     DateTime?
  status        JobStatus @default(DRAFT)

  applications  Application[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([status, publishedAt])
  @@map("job_offers")
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model Application {
  id          String   @id @default(cuid())
  jobOfferId  String
  jobOffer    JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  userId      String   // candidat (User avec role=CANDIDATE)
  user        User     @relation(fields: [userId], references: [id])

  cvUrl       String?
  coverLetter String?  @db.Text
  score       Int?     // 0-100, calculé par tri auto
  stage       AppStage @default(RECEIVED)
  notes       String?  @db.Text

  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobOfferId, userId])
  @@map("applications")
}

enum AppStage {
  RECEIVED
  SHORTLISTED
  INTERVIEW
  TECHNICAL_TEST
  OFFER
  HIRED
  REJECTED
}

// ========================================
// MESSAGERIE
// ========================================

model Conversation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String?  // null pour DM, défini pour groupes
  isGroup     Boolean  @default(false)
  avatarUrl   String?
  // Phase 2 / Bloc 5 — fn 5.4
  isStrategic Boolean  @default(false)
  pinnedAt    DateTime?

  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages    Message[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, lastMessageAt])
  @@index([tenantId, isStrategic])
  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?
  isPinned       Boolean  @default(false)
  isMuted        Boolean  @default(false)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User     @relation("SentMessages", fields: [senderId], references: [id])

  content         String   @db.Text
  attachmentUrl   String?
  attachmentName  String?
  attachmentSize  Int?

  isSystem        Boolean  @default(false) // messages système type "X a partagé un document"

  // Phase 2 / Bloc 5 — fn 5.4
  priority            MessagePriority @default(NORMAL)
  mentions            String[] // userIds mentionnés
  attachedDocumentIds String[] // depuis GED
  pollData            Json?    // { question, options: [{ label, votes: [userId] }] }

  voiceNote       VoiceNote?

  createdAt       DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, priority])
  @@map("messages")
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model VoiceNote {
  id          String   @id @default(cuid())
  messageId   String   @unique
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  audioUrl    String
  durationSec Int
  transcript  String?  @db.Text

  createdAt   DateTime @default(now())

  @@map("voice_notes")
}

// ========================================
// CYCLE DE PAIE DAF (Phase 2 / DAF Bloc 1 — fn 1.4)
// ========================================
// Pilote le cycle mensuel de paie : 7 statuts du calcul à la transmission DIPE.
model PayrollCycle {
  id              String   @id @default(cuid())
  tenantId        String
  period          String   // "2026-04"
  status          PayrollCycleStatus @default(DRAFT)

  totalBulletins  Int      @default(0)
  grossAmount     BigInt   @default(0)
  employerCharges BigInt   @default(0)
  netToPay        BigInt   @default(0)

  startedAt       DateTime
  calculatedAt    DateTime?
  n1ValidatedAt   DateTime?
  n2ValidatedAt   DateTime?
  n3ValidatedAt   DateTime?
  paidAt          DateTime?
  dipeSubmittedAt DateTime?

  warnings        Json     @default("[]") // [{ severity, type, message, count? }]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@map("payroll_cycles")
}

enum PayrollCycleStatus {
  DRAFT
  CALCULATING
  CALCULATED
  N1_PENDING
  N2_PENDING
  N3_PENDING
  PAID
  DIPE_SUBMITTED
  CLOSED
}

// ========================================
// RECOUVREMENT CLIENTS DAF (Phase 2 / DAF Bloc 1 — fn 1.5)
// ========================================
// Créances clients avec balance âgée + niveaux de relance R1/R2/R3.
model Receivable {
  id            String   @id @default(cuid())
  tenantId      String
  invoiceRef    String
  clientName    String
  clientId      String?
  amount        BigInt
  paidAmount    BigInt   @default(0)
  issueDate     DateTime
  dueDate       DateTime
  status        ReceivableStatus @default(OPEN)
  siteId        String?
  daysOverdue   Int      @default(0)

  reminders     Reminder[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, invoiceRef])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@map("receivables")
}

enum ReceivableStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  LITIGATION
  WRITEOFF
}

model Reminder {
  id           String   @id @default(cuid())
  receivableId String
  receivable   Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  level        ReminderLevel
  channel      ReminderChannel
  sentAt       DateTime
  sentBy       String
  responseReceived Boolean @default(false)
  responseDate     DateTime?
  responseNote     String?  @db.Text

  createdAt    DateTime @default(now())

  @@index([receivableId, sentAt])
  @@map("reminders")
}

enum ReminderLevel {
  R1_AMIABLE
  R2_FIRM
  R3_FORMAL_NOTICE
  LITIGATION
}

enum ReminderChannel {
  EMAIL
  LETTER
  REGISTERED_MAIL
  PHONE
  BAILIFF
}

// ========================================
// FISCALITÉ DAF (Phase 2 / DAF Bloc 1 — fn 1.6)
// ========================================
// Échéances fiscales / sociales (TVA, IRPP, CNPS DIPE...) + audits.
model TaxDeadline {
  id                String   @id @default(cuid())
  tenantId          String
  type              TaxType
  authority         TaxAuthority
  period            String   // "2026-04" ou "2025"
  dueDate           DateTime
  amount            BigInt?
  declarationStatus DeclarationStatus @default(PENDING)
  paymentStatus     PaymentStatus     @default(PENDING)
  declaredAt        DateTime?
  paidAt            DateTime?
  receiptUrl        String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, type, period])
  @@index([tenantId, dueDate])
  @@index([tenantId, type])
  @@map("tax_deadlines")
}

enum TaxType {
  VAT
  IRPP
  CNPS_DIPE
  CFC
  FNE
  RAV
  TC
  CAC
  IS_INSTALLMENT
  IS_BALANCE
  DSF_FILING
  TAXES_ANNEXES
  OTHER
}

enum TaxAuthority {
  DGI
  CNPS
  COMMUNE
  CNAM_OCCUPATIONAL
  OTHER
}

enum DeclarationStatus {
  PENDING
  PREPARED
  SUBMITTED
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  SCHEDULED
  PAID
  OVERDUE
}

model TaxAudit {
  id                String   @id @default(cuid())
  tenantId          String
  type              AuditType
  authority         TaxAuthority
  period            String
  auditor           String?
  status            AuditStatus @default(ANNOUNCED)
  startDate         DateTime
  endDate           DateTime?
  opinion           String?  @db.Text
  adjustmentsAmount BigInt?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId, status])
  @@map("tax_audits")
}

enum AuditType {
  TAX_VERIFICATION
  CNPS_CONTROL
  EXTERNAL_AUDIT
  CAC
  INTERNAL
}

enum AuditStatus {
  ANNOUNCED
  IN_PROGRESS
  CONTRADICTORY
  CLOSED
  CHALLENGED
}

// ========================================
// PRÉFÉRENCES DAF (Phase 2 — Bloc DAF, prompt 0)
// ========================================
// Stocke les préférences spécifiques au DAF (1 ligne par utilisateur DAF) :
// seuils d'alertes personnalisés, layout du tableau de bord.
model DafSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  alertsConfig    Json?    // { treasuryMin, dsoMax, validationOverdueDays, ... }
  dashboardLayout Json?    // [{ widget, order, size }]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("daf_settings")
}

// ========================================
// GED
// ========================================

model Document {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  category    String?  // Marché, Plan, Décompte, PV, Photo...
  folder      String?  // chemin virtuel
  mimeType    String
  sizeBytes   BigInt
  url         String   // URL stockage (S3 ou local)

  // Liens contextuels (optionnels)
  siteId      String?
  authorId    String

  // OCR (phase 2)
  ocrContent  String?  @db.Text

  status      DocStatus @default(DRAFT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, folder])
  @@index([tenantId, siteId])
  @@map("documents")
}

enum DocStatus {
  DRAFT
  PUBLISHED
  SIGNED
  ARCHIVED
}

// ========================================
// NOTIFICATIONS
// ========================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // payslip_ready, validation_required, message_received...
  title     String
  body      String?
  link      String?  // chemin app à ouvrir

  read      Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@map("notifications")
}

// ========================================
// AUDIT TRAIL
// ========================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  action      String   // user.login, payslip.validate, site.update...
  entityType  String?
  entityId    String?
  metadata    Json?    // données contextuelles (avant/après, IP, user-agent...)

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ========================================
// VALIDATIONS DG (Phase 2 / Bloc 2 — fn 2.1)
// ========================================
// Demandes nécessitant l'approbation d'un cadre (paie, dépense, achat,
// embauche, marché, congé). Chaque demande porte un workflow JSON avec
// les étapes (initiateur → N1 → N2 → N3) et leurs dates de validation.
model Validation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type            ValidationType
  reference       String   // VAL-2026-0042
  title           String
  description     String?  @db.Text
  amount          BigInt?  // FCFA si applicable

  initiatorId     String
  initiator       User     @relation("ValidationInitiator", fields: [initiatorId], references: [id])

  // Étape courante du workflow (par convention : "RH" | "DAF" | "DG")
  currentStep     String?
  currentApproverId String?
  currentApprover User?    @relation("ValidationCurrentApprover", fields: [currentApproverId], references: [id])

  // Workflow complet (étapes + dates) — { steps: [{ key, label, role, status, decidedBy?, decidedAt? }] }
  workflow        Json
  // Historique commentaires + demandes justification + délégations
  comments        Json     @default("[]")

  status          ValidationStatus @default(PENDING)
  priority        ValidationPriority @default(NORMAL)

  decidedById     String?
  decidedBy       User?    @relation("ValidationDecidedBy", fields: [decidedById], references: [id])
  decisionAt      DateTime?
  decisionReason  String?  @db.Text

  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@index([currentApproverId, status])
  @@index([tenantId, type, status])
  @@map("validations")
}

enum ValidationType {
  PAYROLL
  EXPENSE
  PURCHASE
  HIRING
  CONTRACT
  LEAVE
  OTHER
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum ValidationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Délégations ponctuelles ou permanentes : un cadre délègue ses pouvoirs
// d'approbation à un autre, pour certains types et jusqu'à un montant max.
model Delegation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fromUserId  String
  fromUser    User     @relation("DelegationFrom", fields: [fromUserId], references: [id])
  toUserId    String
  toUser      User     @relation("DelegationTo", fields: [toUserId], references: [id])

  types       ValidationType[]
  maxAmount   BigInt?
  startDate   DateTime
  endDate     DateTime?
  active      Boolean  @default(true)
  reason      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, active])
  @@index([fromUserId, active])
  @@map("delegations")
}

// ========================================
// RAPPORTS CONSOLIDÉS DG (Phase 2 / Bloc 2 — fn 2.2)
// ========================================
// Rapports stratégiques générés par le DG : synthèse exécutive, tableau
// de bord mensuel, bilan annuel, note trimestrielle, rapport sur-mesure.
// Le wizard permet de configurer les blocs (KPIs, graphes, tableaux) et
// d'envoyer le rapport par email aux destinataires.
model Report {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id])

  type          ReportType
  title         String
  period        String   // "S18-2026", "2026-04", "2026-T1"...
  parameters    Json     // { scope, start, end, ... }
  blocks        Json     // [{ type, label, ... }] — bibliothèque de blocs
  data          Json     // snapshot des données calculées au moment de la génération
  pdfUrl        String?
  status        ReportStatus @default(GENERATED)
  scheduledRule String?  // cron-like si rapport planifié
  recipients    Json?    // [{ email, name, sentAt }]
  generatedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("reports")
}

enum ReportType {
  EXECUTIVE_SUMMARY     // Synthèse exécutive hebdo
  MONTHLY_DASHBOARD     // Tableau de bord stratégique mensuel
  ANNUAL_GROUP          // Bilan annuel groupe
  QUARTERLY_NOTE        // Note d'activité trimestrielle
  CUSTOM                // Sur-mesure
}

enum ReportStatus {
  DRAFT
  GENERATED
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

// ========================================
// CONFIGURATION TENANT (Phase 2 / Bloc 2 — fn 2.3)
// ========================================
// Paramétrage du tenant par le DG : identité, modules actifs, plan
// comptable, paramètres paie, workflows de validation, notifications,
// intégrations API. Une seule ligne par tenant.
model TenantSettings {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  identity      Json     // raison sociale, NIU, RCCM, capital, sièges, représentants
  modules       Json     // { msg: true, payroll: true, ... }
  payrollRates  Json     // barèmes IRPP + taux CNPS/CFC/FNE/RAV/TC/CAC/CFS
  workflows     Json     // règles de validation par type
  notifications Json     // matrice destinataires × événements × canaux
  integrations  Json     // clés API (chiffrées) — banques, CNPS, MoMo, Resend

  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@map("tenant_settings")
}

// ========================================
// SESSIONS UTILISATEUR (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Sessions actives suivies pour permettre au DG de voir qui est connecté
// et déconnecter à distance. Une session ≠ un JWT : c'est une trace
// d'identification (IP, user-agent, géoloc).
model Session {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress       String?
  userAgent       String?
  location        String?  // résolu via API IP geolocation
  suspicious      Boolean  @default(false)
  lastActivityAt  DateTime @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([userId, expiresAt])
  @@map("sessions")
}

// ========================================
// RÔLES PERSONNALISÉS (Phase 2 / Bloc 2 — fn 2.4)
// ========================================
// Permet de cloner un rôle système et d'ajuster ses permissions pour un
// tenant donné (ex: "Validateur dérogatoire", "Auditeur externe").
model CustomRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  basedOn     Role
  permissions Json     // { sites: ["read"], payroll: ["read", "write"], ... }
  userCount   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("custom_roles")
}

// ========================================
// CHANTIERS — VUE DG TRANSVERSE (Phase 2 / Bloc 3 — fn 3.1)
// ========================================
// Contrats de marché (initialAmount + avenants), photos chantier,
// alertes (dérives budget, retards, HSE) et décisions DG enregistrées.
model SiteContract {
  id              String   @id @default(cuid())
  siteId          String   @unique
  site            Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  reference       String
  initialAmount   BigInt
  currentAmount   BigInt
  amendments      Json     @default("[]") // [{ ref, amount, date, reason, validatedBy }]
  guarantees      Json     @default("{}") // { caution, retention, penalties }
  paymentTerms    String?
  publicMarket    Boolean  @default(false)
  procuringEntity String?  // MINTP, MINHDU, FEICOM...
  signedAt        DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("site_contracts")
}

model SitePhoto {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url         String
  caption     String?
  takenAt     DateTime
  uploadedBy  String

  createdAt   DateTime @default(now())

  @@index([siteId, takenAt])
  @@map("site_photos")
}

model SiteAlert {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  severity  AlertSeverity
  type      String   // BUDGET_OVERRUN, DELAY, HSE_INCIDENT, MARGIN_DROP, ...
  message   String
  resolved  Boolean  @default(false)
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  @@index([siteId, resolved])
  @@map("site_alerts")
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SiteDecision {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  authorId  String
  title     String
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@map("site_decisions")
}

// ========================================
// PLANNING DG (Phase 2 / Bloc 3 — fn 3.2)
// ========================================
// Jalons stratégiques (réceptions, lancements, échéances fiscales, AG…)
// + conflits ressources détectés (surcharges) à arbitrer par le DG.
model Milestone {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId    String?  // optionnel : jalon d'un chantier précis
  type      MilestoneType
  title     String
  date      DateTime
  critical  Boolean  @default(false)
  status    MilestoneStatus @default(PLANNED)
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, type])
  @@map("milestones")
}

enum MilestoneType {
  SITE_START
  SITE_DELIVERY
  MILESTONE
  FINANCIAL
  COMMERCIAL
  INTERNAL
}

enum MilestoneStatus {
  PLANNED
  IN_PROGRESS
  DONE
  DELAYED
  CANCELLED
}

model ResourceConflict {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  resourceType String   // CREW, EQUIPMENT
  resourceLabel String  // "Maçons coffreurs", "Pelle hydraulique 20T"...
  periodStart  DateTime
  periodEnd    DateTime
  demandLevel  Int      // % de surcharge (>100 = saturé)
  siteIds      String[] // chantiers concernés
  resolved     Boolean  @default(false)
  resolution   String?  @db.Text
  arbitration  Boolean  @default(false) // demande arbitrage DG
  arbitrationStatus ArbitrationStatus @default(PENDING)
  arbitrationNote   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, resolved])
  @@index([tenantId, arbitration])
  @@map("resource_conflicts")
}

enum ArbitrationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

// ========================================
// RH STRATÉGIQUE DG (Phase 2 / Bloc 3 — fn 3.3)
// ========================================
// Plan de succession pour les postes clés, formations historiques /
// planifiées (avec recyclages CACES), indicateurs sociaux mensuels.
model SuccessionPlan {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  positionTitle String   // "Directeur de travaux", "DAF"...
  incumbentId   String
  incumbent     User     @relation("SuccessionIncumbent", fields: [incumbentId], references: [id])
  successorId   String?
  successor     User?    @relation("SuccessionSuccessor", fields: [successorId], references: [id])
  readyInMonths Int?
  status        SuccessionStatus @default(NONE)
  notes         String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, positionTitle])
  @@index([tenantId, status])
  @@map("succession_plans")
}

enum SuccessionStatus {
  IDENTIFIED
  AT_RISK
  NONE
  READY_NOW
}

model Training {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  category      String   // CACES, sécurité, métier, management...
  provider      String?
  startDate     DateTime
  endDate       DateTime
  cost          BigInt?
  status        TrainingStatus @default(PLANNED)
  certificateUrl String?
  expiresAt     DateTime? // pour recyclage obligatoire

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@map("trainings")
}

enum TrainingStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model SocialIndicator {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period    String   // "2026-04"
  // Stocké en JSON pour souplesse : turnover, absenteeism, climate, conflicts...
  indicators Json

  createdAt DateTime @default(now())

  @@unique([tenantId, period])
  @@map("social_indicators")
}

// ========================================
// FINANCES DG (Phase 2 / Bloc 4 — fn 4.1)
// ========================================
// Snapshot mensuel : compte de résultat (P&L), bilan synthétique, BFR.
// Une ligne par mois. Verrouillage après clôture comptable.
model FinancialPeriod {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period    String   // "2026-04" ou "2026-BUDGET" pour budget
  pnl       Json     // { products: {...}, expenses: {...}, results: {...} }
  balance   Json     // { actif: {...}, passif: {...}, ratios: {...} }
  bfr       Json     // { dso, dpo, stockRotation, bfr, treasury }
  locked    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, period])
  @@map("financial_periods")
}

// Engagements financiers : cautions, GAPD, lettres de crédit, BC long terme.
model FinancialCommitment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        CommitmentType
  reference   String?
  bank        String?
  beneficiary String?
  amount      BigInt
  siteId      String?
  issueDate   DateTime
  maturityDate DateTime
  status      CommitmentStatus @default(ACTIVE)
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("financial_commitments")
}

enum CommitmentType {
  BANK_GUARANTEE
  FIRST_DEMAND_GUARANTEE
  LETTER_CREDIT
  PURCHASE_COMMITMENT
}

enum CommitmentStatus {
  ACTIVE
  EXPIRED
  RELEASED
  CALLED
}

// Comptes bancaires : solde JJ + lignes accordées/utilisées + relation manager.
// Étendu DAF (Bloc 1 / fn 1.2) : syncStatus + lastSyncAt + primaryColor + movements.
model BankAccount {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bank              String   // UBA, BICEC, AFRILAND, ECOBANK, SGBC...
  accountNumber     String
  accountType       String   @default("CURRENT") // CURRENT, ESCROW, SAVING, GUARANTEE, FOREIGN_CURRENCY
  currency          String   @default("XAF")
  balance           BigInt
  creditLineGranted BigInt   @default(0)
  creditLineUsed    BigInt   @default(0)
  renewalDate       DateTime?
  contact           Json?    // { name, phone, email }
  history12m        Json     @default("[]") // [{ month, balance }]

  // DAF fn 1.2 — synchro temps réel
  lastSyncAt        DateTime?
  syncStatus        BankSyncStatus @default(MANUAL)
  primaryColor      String?  // pour code couleur visuel UBA rouge, BICEC sarcelle...

  movements         BankMovement[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
  @@map("bank_accounts")
}

enum BankSyncStatus {
  LIVE
  DELAYED
  MANUAL
  ERROR
}

// Mouvements bancaires (DAF Bloc 1 / fn 1.2). Trace des entrées / sorties par compte.
model BankMovement {
  id            String   @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  direction     MovementDirection
  amount        BigInt
  label         String
  reference     String?
  counterparty  String?
  siteId        String?
  occurredAt    DateTime

  createdAt     DateTime @default(now())

  @@index([bankAccountId, occurredAt])
  @@map("bank_movements")
}

enum MovementDirection {
  INBOUND
  OUTBOUND
}

// ========================================
// COMPTABILITÉ DG (Phase 2 / Bloc 4 — fn 4.2)
// ========================================
// Périodes comptables (mensuelles + clôture annuelle), écritures
// SYSCOHADA. V1 : structure conforme, calcul brouillon — validation
// expert-comptable agréé OHADA requise pour la prod.
model AccountingPeriod {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period        String   // "2026-04" ou "2026" pour annuel
  status        PeriodStatus @default(OPEN)
  closedAt      DateTime?
  closedBy      String?
  totalEntries  Int      @default(0)
  totalDebit    BigInt   @default(0)
  totalCredit   BigInt   @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, period])
  @@map("accounting_periods")
}

enum PeriodStatus {
  OPEN
  CLOSING
  CLOSED
  LOCKED
}

// Écriture comptable simplifiée (V1) avec lignes débit/crédit.
model AccountingEntry {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period    String   // "2026-04"
  reference String   // PIE-2026-001
  date      DateTime
  journal   String   // OD, AC, BQ, VE, OD
  label     String
  totalDebit  BigInt
  totalCredit BigInt

  lines     AccountingLine[]
  createdAt DateTime @default(now())

  @@unique([tenantId, reference])
  @@index([tenantId, period])
  @@map("accounting_entries")
}

model AccountingLine {
  id        String   @id @default(cuid())
  entryId   String
  entry     AccountingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  account   String   // numéro SYSCOHADA (4 à 6 chiffres)
  label     String
  debit     BigInt   @default(0)
  credit    BigInt   @default(0)

  @@index([account])
  @@map("accounting_lines")
}

// Clôture annuelle avec workflow DG en 5 étapes.
model AnnualClosure {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fiscalYear      Int
  status          ClosureStatus @default(IN_PROGRESS)
  pnlValidated    Boolean  @default(false)
  balanceValidated Boolean @default(false)
  adjustmentsValidated Boolean @default(false)
  draftGenerated  Boolean  @default(false)
  adjustments     Json     @default("[]")
  dgValidatedAt   DateTime?
  dgValidatedBy   String?
  submittedToDgi  Boolean  @default(false)
  dsfFileUrl      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, fiscalYear])
  @@map("annual_closures")
}

enum ClosureStatus {
  IN_PROGRESS
  PENDING_DG_VALIDATION
  VALIDATED
  SUBMITTED
}

// ========================================
// ACHATS DG (Phase 2 / Bloc 4 — fn 4.3)
// ========================================
// Fournisseurs, contrats-cadres, BC en attente validation DG, évaluations.
model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name          String
  category      String   // Ciment, Acier, Carburant, Engins, Sous-traitance...
  taxId         String?  // NIU
  rccm          String?
  phone         String?
  email         String?
  address       String?
  paymentTerms  Int      @default(45) // jours
  ratingQuality Float?   // 1-5
  ratingDelay   Float?
  ratingPrice   Float?
  strategic     Boolean  @default(false)
  blocked       Boolean  @default(false)
  blockReason   String?
  volumeYTD     BigInt   @default(0)
  poCount       Int      @default(0)

  contracts     FrameworkContract[]
  evaluations   SupplierEvaluation[]
  purchaseOrders PurchaseOrder[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, strategic])
  @@index([tenantId, category])
  @@map("suppliers")
}

model FrameworkContract {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  reference   String
  subject     String
  maxAmount   BigInt
  usedAmount  BigInt   @default(0)
  startDate   DateTime
  endDate     DateTime
  conditions  Json?
  status      ContractStatus @default(DRAFT)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@map("framework_contracts")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model SupplierEvaluation {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  evaluatorId  String
  period       String
  ratingQuality Float
  ratingDelay   Float
  ratingPrice   Float
  comments     String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([supplierId, createdAt])
  @@map("supplier_evaluations")
}

// Bons de commande avec workflow validation DG (montant > seuil)
model PurchaseOrder {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  reference   String
  label       String
  amount      BigInt
  category    String
  initiatorId String
  status      PoStatus @default(PENDING_DAF)
  dafApprovedAt DateTime?
  dafApprovedBy String?
  dgDecisionAt DateTime?
  dgDecisionBy String?
  dgDecisionNote String?
  rejectionReason String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

enum PoStatus {
  DRAFT
  PENDING_DAF
  PENDING_DG
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// STOCKS & MATÉRIEL DG (Phase 2 / Bloc 5 — fn 5.1)
// ========================================
// Immobilisations significatives, mouvements de stock (avec détection
// d'anomalies), inventaires et sinistres.
model FixedAsset {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code          String
  description   String
  category      AssetCategory
  acquisitionDate DateTime
  grossValue    BigInt
  accumulatedDepreciation BigInt @default(0)
  netValue      BigInt   // VNC = grossValue - accumulatedDepreciation
  usefulLifeMonths Int
  siteId        String?
  condition     String   @default("GOOD") // EXCELLENT, GOOD, FAIR, POOR
  insurance     Json?    // { company, policyRef, expiresAt, coveredAmount }
  lastRevaluedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, category])
  @@map("fixed_assets")
}

enum AssetCategory {
  EQUIPMENT
  VEHICLE
  BUILDING
  TOOLING
  IT
  FURNITURE
  OTHER
}

model StockMovement {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type         MovementType
  itemCode     String
  itemLabel    String
  quantity     Float
  unitValue    BigInt
  totalValue   BigInt
  fromSiteId   String?
  toSiteId     String?
  reason       String?
  initiatorId  String
  anomalous    Boolean  @default(false)
  anomalyReason String?

  createdAt    DateTime @default(now())

  @@index([tenantId, anomalous])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
  WRITEOFF
}

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId        String?
  period        String // "2026-04"
  items         Json     @default("[]") // [{ code, label, theoretical, counted, gap }]
  itemsCount    Int      @default(0)
  gapsCount     Int      @default(0)
  gapsValue     BigInt   @default(0)
  status        InventoryStatus @default(PLANNED)
  dgValidated   Boolean  @default(false)
  startDate     DateTime
  endDate       DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, status])
  @@map("inventories")
}

enum InventoryStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  VALIDATED
}

model Loss {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type        LossType
  itemDescription String
  value       BigInt
  siteId      String?
  occurredAt  DateTime
  declaredToInsurance Boolean @default(false)
  declaredAt  DateTime?
  indemnification BigInt?
  correctiveActions String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, type])
  @@map("losses")
}

enum LossType {
  THEFT
  DAMAGE
  LOSS
  OTHER
}

// ========================================
// MON PROFIL DG (Phase 2 / Bloc 5 — fn 5.2)
// ========================================
// Préférences DG, signature numérique, agenda, déclarations d'intérêts.
model UserPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  dashboardWidgets     Json     @default("[]")
  alertThresholds      Json     @default("{}")
  notificationChannels Json     @default("{}")
  dailyReportEnabled   Boolean  @default(false)
  dailyReportTime      String?  // "07:00"
  numberFormat         String   @default("M_FCFA") // M_FCFA, MD_FCFA, RAW

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("user_preferences")
}

model UserSignature {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  signatureUrl String?
  initialsUrl  String?
  uploadedAt   DateTime?

  @@map("user_signatures")
}

model AgendaEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?  @db.Text
  startAt     DateTime
  endAt       DateTime
  location    String?
  type        EventType @default(MEETING)
  externalId  String?  // pour sync Google/Outlook

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, startAt])
  @@map("agenda_events")
}

enum EventType {
  MEETING
  BOARD
  AUDIT
  VALIDATION_DEADLINE
  PERSONAL
  OTHER
}

model InterestDeclaration {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year                Int
  mandates            Json     @default("[]") // [{ entity, role, since, end? }]
  shareholdings       Json     @default("[]") // [{ entity, percent, value? }]
  conflictsOfInterest Json     @default("[]") // [{ description, mitigation }]
  declaredAt          DateTime
  validUntil          DateTime

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, year])
  @@map("interest_declarations")
}

// ========================================
// PAIE DG ENRICHIE (Phase 2 / Bloc 5 — fn 5.3)
// ========================================
// Avantages en nature et bonus de performance pour le DG (et autres
// cadres dirigeants). Évaluation conforme barème CNPS Cameroun.
model BenefitInKind {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type         BenefitType
  description  String
  monthlyValue BigInt   // valeur réelle
  fiscalValue  BigInt   // selon barème CNPS
  startDate    DateTime
  endDate      DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, type])
  @@map("benefits_in_kind")
}

enum BenefitType {
  HOUSING
  VEHICLE
  FUEL
  PHONE
  INSURANCE
  OTHER
}

model PerformanceBonus {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fiscalYear   Int
  bonusType    BonusType
  formula      String?
  targetAmount BigInt
  actualAmount BigInt?
  status       BonusStatus @default(TARGETED)
  paidAt       DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, fiscalYear])
  @@map("performance_bonuses")
}

enum BonusType {
  ANNUAL_RESULT
  OBJECTIVES
  SIGNING
  RETENTION
}

enum BonusStatus {
  TARGETED
  PROVISIONED
  VALIDATED
  PAID
}
