model SiteDocument {
  id           String           @id @default(cuid())
  siteId       String
  site         Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  category     DocumentCategory
  // Sous-catégorie libre pour préciser (ex : "Caution bancaire BICEC" ou
  // "Mois d'avril décompte n°4"). Utilisé pour affichage et recherche.
  subCategory  String?
  title        String
  description  String?
  fileUrl      String
  fileName     String
  fileSize     Int
  mimeType     String
  thumbnailUrl String?

  // Métadonnées spécifiques cautions/assurances/décomptes
  referenceNumber  String? // n° du document (ex : caution 2026-04-1854)
  issuedAt         DateTime? // date émission
  validUntil       DateTime? // date validité (cautions/assurances)
  amount           BigInt? // montant pour cautions et décomptes (FCFA)
  relatedPartyName String? // banque émettrice, assureur, signataire

  uploadedById String
  uploadedBy   User     @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedAt   DateTime @default(now())

  // Archivage non-destructif ("réduit" demandé par l'utilisateur)
  archived   Boolean   @default(false)
  archivedAt DateTime?

  tags       String[] @default([])
  metadata   Json? // EXIF photos, géoloc, version plans...
  ocrContent String?  @db.Text

  @@index([siteId, category])
  @@index([siteId, uploadedAt])
  @@index([siteId, archived])
  @@index([validUntil]) // pour les alertes expiration
  @@map("site_documents")
}

