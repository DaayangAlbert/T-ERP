  inputs PayrollInput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@map("payroll_cycles")
}

enum PayrollCycleStatus {
  DRAFT
  CALCULATING
  CALCULATED
  N1_PENDING
  N2_PENDING
  N3_PENDING
  PAID
  DIPE_SUBMITTED
