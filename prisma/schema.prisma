  closedAt DateTime?

  movements CashboxMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cpt_site_cashboxes")
}

model CashboxMovement {
  id        String      @id @default(cuid())
  cashboxId String
  cashbox   SiteCashbox @relation(fields: [cashboxId], references: [id], onDelete: Cascade)

  direction   CashDirection
  amount      BigInt
  reason      String
  reference   String?
  attachments String[]      @default([])
  occurredAt  DateTime

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  createdAt DateTime @default(now())

  @@index([cashboxId, occurredAt])
  @@map("cpt_cashbox_movements")
}

enum CashDirection {
  IN
  OUT
}

// ============================================================
// CPT — COMPTABILITÉ ANALYTIQUE PAR PROJET (DAF + Comptable)
// ============================================================
// Chaque chantier dispose d'un « compte projet » adossé à un compte
// bancaire réel de l'entreprise. Il suit crédits (approvisionnement,
// production) et débits (dépenses, salaires propres, quote-part siège,
// remboursements). Le solde peut être NÉGATIF = dette du projet tant
// qu'il n'a pas produit. Un compte salaire global par tenant centralise
// la masse salariale ; la quote-part siège est répartie au prorata du
// montant de chaque marché.
// ============================================================

// Direction d'un mouvement analytique : CREDIT augmente le solde
// (entrée / disponibilité), DEBIT le diminue (sortie / dette).
enum CptDirection {
  CREDIT
  DEBIT
}

// Nature d'un mouvement de compte projet.
enum ProjectAccountEntryType {
  FUNDING // approvisionnement depuis la banque (crédit)
  EXPENSE // dépense projet (débit)
  PROJECT_SALARY // salaire du personnel propre au chantier (débit)
  OVERHEAD_SALARY // quote-part masse salariale siège (débit)
  REVENUE // encaissement / production (crédit)
  REPAYMENT // remboursement vers la banque (débit)
  ADJUSTMENT // régularisation (crédit ou débit)
}

model ProjectAccount {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Compte bancaire réel auquel ce compte projet est adossé (source des
  // approvisionnements). Optionnel : un compte projet peut être ouvert avant
  // d'être rattaché à une banque.
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  // Solde analytique. Peut être négatif = dette du projet.
  balance BigInt @default(0)

  isActive Boolean   @default(true)
  closedAt DateTime?

  movements ProjectAccountMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("cpt_project_accounts")
}

model ProjectAccountMovement {
  id        String         @id @default(cuid())
  accountId String
  account   ProjectAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type       ProjectAccountEntryType
  direction  CptDirection
  amount     BigInt // toujours positif ; le signe vient de `direction`
  reason     String
  reference  String?
  occurredAt DateTime

  // Solde du compte après application du mouvement (audit / relevé).
  balanceAfter BigInt

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  // Rattachement optionnel à une répartition de charges siège.
  overheadRunId String?
  overheadRun   OverheadRun? @relation(fields: [overheadRunId], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, occurredAt])
  @@map("cpt_project_account_movements")
}

// Compte salaire global du tenant : centralise la masse salariale payée
// par les projets (salaires propres + quote-parts siège).
model SalaryAccount {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])

  balance BigInt @default(0)

  movements SalaryAccountMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cpt_salary_accounts")
}

model SalaryAccountMovement {
  id        String        @id @default(cuid())
  accountId String
  account   SalaryAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  direction  CptDirection
  amount     BigInt
  reason     String
  reference  String?
  occurredAt DateTime

  balanceAfter BigInt

  // Chantier d'origine (pour une quote-part / salaire projet).
  siteId String?

  recordedById String
  recordedBy   User   @relation(fields: [recordedById], references: [id])

  overheadRunId String?
  overheadRun   OverheadRun? @relation(fields: [overheadRunId], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, occurredAt])
  @@map("cpt_salary_account_movements")
}

// Répartition de la masse salariale siège sur les projets, au prorata du
// montant des marchés. Un run = un mois (ou une période) avec un montant
// total à répartir. Le run garde la trace de la base de calcul pour audit.
model OverheadRun {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period      String // "2026-05"
  totalAmount BigInt // masse salariale siège à répartir
  basis       Json // [{ siteId, code, marketAmount, weight, share }]
  status      OverheadRunStatus @default(PENDING)

  executedById String?
  executedBy   User?     @relation("OverheadRunExecutor", fields: [executedById], references: [id])
  executedAt   DateTime?

  projectMovements ProjectAccountMovement[]
  salaryMovements  SalaryAccountMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
  @@map("cpt_overhead_runs")
}

enum OverheadRunStatus {
  PENDING // prévisualisé, non appliqué
  APPLIED // mouvements générés
  CANCELLED
}

