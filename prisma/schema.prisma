model Warehouse {
  id       String  @id @default(cuid())
  tenantId String
  // siteId est nullable depuis l'ajout du champ `scope` : un magasin
  // peut être rattaché à un chantier (scope=CHANTIER, siteId requis), à
  // une direction de l'entreprise (scope=DIRECTION, ownerDirection
  // requis, siteId null) ou être un magasin central groupe
  // (scope=CENTRAL, les deux null).
  siteId   String? @unique
  site     Site?   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  code     String
  name     String
  keeperId String?
  keeper   User?   @relation("WarehouseKeeper", fields: [keeperId], references: [id])

  // Qualification du magasin : chantier / direction / central.
  // Sert au filtrage côté ADMIN/DAF dans /stocks et /magasin.
  scope          WarehouseScope @default(CHANTIER)
  // Si scope=DIRECTION, indique quelle direction "possède" ce magasin
  // (DG, DAF, HR, TECH_DIRECTOR, WORKS_DIRECTOR, SECRETARY_GENERAL...).
  // null pour les magasins de chantier ou centraux.
  ownerDirection Role?

  stocks           WarehouseStock[]
  movements        WarehouseMovement[]
  inventories      WarehouseInventory[]
  materialRequests MaterialRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, scope])
  @@index([tenantId, ownerDirection])
  @@map("warehouses")
}

// ============================================================================
// DEMANDES DE MATÉRIEL — Chef de Chantier → Magasin
// ============================================================================
// Workflow : CC crée une demande pour son chantier, le magasinier
// (Warehouse.keeperId) la voit, l'honore (création des
// WarehouseMovement OUT en transaction) ou la refuse avec motif.

model MaterialRequest {
  id              String                  @id @default(cuid())
  tenantId        String
  // Demandeur (typiquement un SITE_MANAGER)
  requesterId     String
  requester       User                    @relation("MaterialRequester", fields: [requesterId], references: [id])
  // Chantier qui consomme
  siteId          String
  site            Site                    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  // Magasin sollicité (peut être celui du chantier ou un autre du tenant)
  warehouseId     String
  warehouse       Warehouse               @relation(fields: [warehouseId], references: [id])
  // Référence lisible (auto : MR-{site.code}-{yyyymm}-{seq})
  reference       String                  @unique
  status          MaterialRequestStatus   @default(PENDING)
  // Urgence affichée au magasinier (LOW/NORMAL/HIGH/URGENT)
  priority        MaterialRequestPriority @default(NORMAL)
  reason          String? // contexte / phase / tâche
  notes           String? // notes du demandeur
  // Traitement
  fulfilledById   String?
  fulfilledBy     User?                   @relation("MaterialFulfiller", fields: [fulfilledById], references: [id])
  fulfilledAt     DateTime?
  rejectionReason String?
  rejectedAt      DateTime?

  lines MaterialRequestLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([warehouseId, status])
  @@index([requesterId])
  @@index([siteId])
  @@map("material_requests")
}

model MaterialRequestLine {
  id                String          @id @default(cuid())
  requestId         String
  request           MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  articleId         String
  article           Article         @relation(fields: [articleId], references: [id])
  // Quantité demandée par le CC
  quantityRequested Float
  // Quantité réellement servie par le magasinier (peut être < ou = à demandé)
  quantityFulfilled Float?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([articleId])
  @@map("material_request_lines")
}

enum MaterialRequestStatus {
  PENDING // demande créée par le CC, en attente magasinier
  FULFILLED // magasinier a sorti le matériel (mouvements OUT créés)
  PARTIAL // sortie partielle (quantityFulfilled < quantityRequested)
  REJECTED // refusée par le magasinier
  CANCELLED // annulée par le CC avant traitement
}

enum MaterialRequestPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WarehouseScope {
  CHANTIER // magasin rattaché à un chantier (Site)
  DIRECTION // magasin rattaché à une direction de l'entreprise
  CENTRAL // magasin central groupe (transverse)
}

model WarehouseStock {
  id           String    @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  articleId    String
  article      Article   @relation(fields: [articleId], references: [id])
  quantity     Float     @default(0)
  pmpUnitPrice BigInt    @default(0)
  totalValue   BigInt    @default(0)
  minThreshold Float?
  lastInAt     DateTime?
  lastOutAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warehouseId, articleId])
  @@index([warehouseId])
  @@map("warehouse_stocks")
}

model WarehouseMovement {
  id                String                     @id @default(cuid())
  warehouseId       String
  warehouse         Warehouse                  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  articleId         String
  article           Article                    @relation(fields: [articleId], references: [id])
  direction         WarehouseMovementDirection
  quantity          Float
  unitPrice         BigInt
  totalValue        BigInt
  reference         String
  reason            WarehouseMovementReason
  supplierId        String?
  deliveryId        String?
  destinationTeamId String?
  destinationUserId String?
  signaturePhoto    String?
  blPhoto           String?
  notes             String?
  recordedById      String
  recordedBy        User                       @relation("WarehouseMovementRecorder", fields: [recordedById], references: [id])
  occurredAt        DateTime
  syncedFromOffline Boolean                    @default(false)
  clientUuid        String?

  createdAt DateTime @default(now())

  @@index([warehouseId, occurredAt])
  @@index([articleId])
  @@index([direction])
  @@map("warehouse_movements")
}

enum WarehouseMovementDirection {
  IN
  OUT
  ADJUSTMENT_PLUS
  ADJUSTMENT_MINUS
}

enum WarehouseMovementReason {
  PURCHASE_DELIVERY
  RETURN
  CONSUMPTION_TEAM
  CONSUMPTION_ENGINE
  INVENTORY_ADJUSTMENT
  DAMAGE_LOSS
  TRANSFER_OUT
  TRANSFER_IN
}

model WarehouseInventory {
  id            String                   @id @default(cuid())
  warehouseId   String
  warehouse     Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  type          WarehouseInventoryType
  scope         String
  plannedDate   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  completedById String?
  completedBy   User?                    @relation(fields: [completedById], references: [id])
  totalGapValue BigInt                   @default(0)
  status        WarehouseInventoryStatus @default(PLANNED)
  lines         WarehouseInventoryLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([warehouseId, status])
  @@map("warehouse_inventories")
}

enum WarehouseInventoryType {
  MONTHLY
  ROLLING_WEEKLY
  ROLLING_BIWEEKLY
  ROLLING_MONTHLY
  ANNUAL
  ADHOC
}

enum WarehouseInventoryStatus {
  PLANNED
  IN_PROGRESS
  PENDING_VALIDATION
  COMPLETED
  CANCELLED
}

model WarehouseInventoryLine {
  id             String             @id @default(cuid())
  inventoryId    String
  inventory      WarehouseInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  articleId      String
  article        Article            @relation(fields: [articleId], references: [id])
  theoreticalQty Float
  countedQty     Float              @default(0)
  gap            Float              @default(0)
  gapValue       BigInt             @default(0)
  justification  String?
  countedAt      DateTime?
  countedById    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inventoryId])
  @@map("warehouse_inventory_lines")
}

// ============================================================
// LOG — LOGISTICIEN SIÈGE (Bloc 0 + 1)
// ============================================================
// Robert ETONDÉ — vue consolidée 23 chantiers, achats, flotte 42 engins,
// transferts inter-chantiers, contrats-cadres fournisseurs.
// ============================================================

// Bloc 1 / fn 1.4 — Flotte d'engins et véhicules
model Equipment {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registration     String // immatriculation (ex: EN-2019-008)
  designation      String // "Pelle CAT 320"
  type             EquipmentType
  acquisitionDate  DateTime?
  acquisitionValue BigInt
  currentValue     BigInt
  status           EquipmentStatus @default(IN_SERVICE)
  // true = engin loué à un tiers (coût récurrent) ; false = propriété de l'entreprise.
  isRented         Boolean         @default(false)
  counterUnit      String          @default("h") // "h" engins TP, "km" véhicules
  counter          Float           @default(0)
  insuranceUntil   DateTime?
  visiteUntil      DateTime?

  assignments  EquipmentAssignment[]
  maintenances MaintenanceSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, registration])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("equipment")
}

enum EquipmentType {
  TP_HEAVY // Engins TP (pelles, bulldozers, chargeuses, niveleuses)
  TRUCK // Camions
  CONCRETE_MIXER // Bétonnières / centrales mobiles
  SERVICE_VEHICLE // Véhicules de service
  OTHER
}

enum EquipmentStatus {
  IN_SERVICE
  MAINTENANCE
  BREAKDOWN
  RETIRED
  TRANSFER // en cours de transfert inter-chantiers
}

// Bloc 1 / fn 1.4 — Affectation engin × chantier × conducteur
model EquipmentAssignment {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?     @relation(fields: [siteId], references: [id])
  driverId    String?
  driver      User?     @relation("EquipmentDriver", fields: [driverId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  active      Boolean   @default(true)
  notes       String?

  createdAt DateTime @default(now())

  @@index([equipmentId, active])
  @@index([siteId])
  @@map("equipment_assignments")
}

// Bloc 1 / fn 1.4 — Plan de maintenance préventive et curative
model MaintenanceSchedule {
  id          String            @id @default(cuid())
  equipmentId String
  equipment   Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  type        MaintenanceType
  description String
  // Critères de déclenchement
  scheduledAt DateTime?
  triggerAt   Float? // valeur compteur déclencheur (ex: 5000 h)
  // Réalisation
  completedAt DateTime?
  cost        BigInt? // coût réel
  vendorName  String? // garage externe ou interne
  status      MaintenanceStatus @default(PLANNED)
  notes       String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([equipmentId, scheduledAt])
  @@index([status])
  @@map("maintenance_schedules")
}

enum MaintenanceType {
  PREVENTIVE_SMALL // Petite révision (250h, 5000 km)
  PREVENTIVE_BIG // Grande révision (1000h, 20000 km)
  ANNUAL_INSPECTION // Visite technique annuelle
  CURATIVE // Panne / réparation
  INSURANCE_RENEWAL // Renouvellement assurance
  REGULATORY // Contrôle réglementaire BTP
}

enum MaintenanceStatus {
  PLANNED
  IN_PROGRESS
  DONE
  OVERDUE
  CANCELLED
}

// Bloc 1 / fn 1.5 — Transferts inter-chantiers
model InterSiteTransfer {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference        String // TR-2026-0042
  fromSiteId       String
  fromSite         Site             @relation("TransferFromSite", fields: [fromSiteId], references: [id])
  toSiteId         String
  toSite           Site             @relation("TransferToSite", fields: [toSiteId], references: [id])
  category         String // "Coffrage", "Engin TP", "Ciment"...
  priority         TransferPriority @default(NORMAL)
  status           TransferStatus   @default(PENDING)
  estimatedSavings BigInt           @default(0) // FCFA économisés vs achat neuf
  context          String?          @db.Text
  arbitratedById   String?
  arbitratedBy     User?            @relation("TransferArbitrator", fields: [arbitratedById], references: [id])
  arbitratedAt     DateTime?
  arbitrationNote  String?          @db.Text
  scheduledAt      DateTime?
  completedAt      DateTime?

  items InterSiteTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reference])
  @@index([tenantId, status])
  @@map("inter_site_transfers")
}

enum TransferPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  SCHEDULED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

// Bloc 1 / fn 1.5 — Articles d'un transfert (matières) ou engin
model InterSiteTransferItem {
  id          String            @id @default(cuid())
  transferId  String
  transfer    InterSiteTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  designation String
  quantity    Float
  unit        String

  @@index([transferId])
  @@map("inter_site_transfer_items")
}

// ========================================
// INFORMATICIEN — BLOC 0 + 1 : INTEGRATIONS, API KEYS, WEBHOOKS, LOGS
// ========================================
model Integration {
