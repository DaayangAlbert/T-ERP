// ========================================
// EMP — Vue détaillée du pointage employé (Bloc 0 / fn 1.4)
// ========================================
// Pour chaque journée travaillée d'un employé, conserve l'heure d'arrivée, de
// départ, la pause, le total d'heures (normales + sup) ainsi que la traçabilité
// du pointeur (CC pour les ouvriers, badge automatique pour les bureaux).
//
// Une contestation peut être ouverte par l'employé via `contestedAt` /
// `contestReason` et résolue par le CC ou le DTrav (`resolvedAt`, `resolvedBy`).
model TimeReport {
  id                String     @id @default(cuid())
  tenantId          String
  userId            String
  user              User       @relation("TimeReportOwner", fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime   @db.Date
  siteId            String? // chantier d'affectation pour les ouvriers
  arrivalTime       DateTime?
  departureTime     DateTime?
  breakMinutes      Int        @default(60)
  totalHours        Float      @default(0)
  standardHours     Float      @default(0)
  overtimeHours     Float      @default(0)
  overtimeType      String? // "evening_125" | "night_150" | "sunday_200"
  status            TimeStatus @default(PRESENT)
  // Pointeur (Chef Chantier pour ouvriers, "AUTO_BADGE" pour bureaux,
  // "SELF_OUV" pour pointage autonome ouvrier via PWA)
  pointedBy         String
  pointer           User?      @relation("TimeReportPointer", fields: [pointedBy], references: [id])
  // OUV — pointage autonome avec GPS + selfie (Bloc 0 Ouvrier fn 1.2)
  entryGeoLat       Float?
  entryGeoLng       Float?
  entryGeoAccuracyM Int?
  entrySelfieUrl    String? // R2 URL /tenants/{slug}/clocks/{userId}/{date}-in.webp
  exitGeoLat        Float?
  exitGeoLng        Float?
  exitGeoAccuracyM  Int?
  exitSelfieUrl     String?
  deviceFingerprint String? // identifiant appareil pour anti-fraude
  outOfGeofence     Boolean    @default(false) // distance > 100m flag
  // Contestation
  contestedAt       DateTime?
  contestReason     String?
  resolvedAt        DateTime?
  resolvedBy        String?
  resolver          User?      @relation("TimeReportResolver", fields: [resolvedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([tenantId, date])
  @@index([siteId, date])
  @@map("time_reports")
}

enum TimeStatus {
  PRESENT
  ABSENT_JUSTIFIED
  ABSENT_UNJUSTIFIED
  HOLIDAY // jour férié
  LEAVE // congé approuvé
  SICK // arrêt maladie
}

