}

enum BenefitType {
  HOUSING
  VEHICLE
  FUEL
  PHONE
  INSURANCE
  OTHER
}

model PerformanceBonus {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fiscalYear   Int
  bonusType    BonusType
  formula      String?
  targetAmount BigInt
  actualAmount BigInt?
