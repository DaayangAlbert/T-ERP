// NOTIFICATIONS
// ========================================

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type  String // payslip_ready, validation_required, message_received...
  title String
  body  String?
  link  String? // chemin app à ouvrir

  read   Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

