  // { draftEntriesAlert?: bool, invoiceDueAlert?: bool, bankReconciliationAlert?: bool, channel?: 'email'|'push'|'in-app' }
  cptAlerts Json?

  // DT Bloc 2 / fn 2.3 — préférences alertes techniques
  // { costDeviationThreshold, delayThresholdDays, marginThresholdPercent, crewLoadThresholdPercent, channel: 'email'|'push'|'in-app' }
  dtAlerts Json?

