  @@map("qhse_monthly_reports")
}

enum QhseMonthlyReportStatus {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
}

// ========================================
// Module DAF — Rapport financier mensuel vers DG
// (Directeur Administratif et Financier consolide P&L, trésorerie,
// créances, dettes, paie, fiscal — destiné à la décision COMEX)
// ========================================

model DafMonthlyFinancialReport {
  id       String @id @default(cuid())
  tenantId String

  authorId String
  author   User   @relation("DafMonthlyFinancialReportAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  period      DateTime // 1er du mois couvert
  periodLabel String? // "Avril 2026"
  status      DafMonthlyFinancialReportStatus @default(DRAFT)

  // ── 1) Performance financière (P&L mensuel) ─────────────────────────
  revenueMonthXAF       BigInt @default(0) // CA produit du mois
  revenueYtdXAF         BigInt @default(0) // CA cumul YTD
  revenueBudgetMonthXAF BigInt @default(0) // CA budgété mois
  expensesMonthXAF      BigInt @default(0) // charges du mois
  grossMarginXAF        BigInt @default(0) // marge brute
  grossMarginPercent    Float  @default(0)
  netMarginXAF          BigInt @default(0) // marge nette
  netMarginPercent      Float  @default(0)
  ebitdaXAF             BigInt @default(0)
  ebitdaPercent         Float  @default(0)

  // ── 2) Trésorerie ──────────────────────────────────────────────────
  cashBalanceXAF           BigInt @default(0) // solde trésorerie fin de mois
  cashVariationXAF         BigInt @default(0) // Δ vs mois précédent
  creditLinesUsedXAF       BigInt @default(0) // lignes utilisées
  creditLinesAvailableXAF  BigInt @default(0) // capacité restante
  capacityAutofinancingXAF BigInt @default(0) // CAF du mois

  // ── 3) Créances clients (BFR) ──────────────────────────────────────
  accountsReceivableXAF  BigInt @default(0) // encours total
  overdueReceivablesXAF  BigInt @default(0) // créances échues
  doubtfulReceivablesXAF BigInt @default(0) // créances douteuses
  dso                    Float  @default(0) // Days Sales Outstanding

  // ── 4) Dettes fournisseurs ────────────────────────────────────────
  accountsPayableXAF BigInt @default(0) // encours total
  overduePayablesXAF BigInt @default(0) // dettes échues
  dpo                Float  @default(0) // Days Payable Outstanding

  // ── 5) Structure financière ───────────────────────────────────────
  workingCapitalNeedXAF BigInt @default(0) // BFR
  financialDebtLtXAF    BigInt @default(0) // dette financière long terme
  financialDebtStXAF    BigInt @default(0) // dette financière court terme
  gearingPercent        Float  @default(0) // dette / fonds propres
  capexMonthXAF         BigInt @default(0) // investissements du mois

  // ── 6) Paie & masse salariale ─────────────────────────────────────
  payrollMassMonthXAF     BigInt @default(0) // masse salariale du mois (brut+charges)
  payrollHeadcount        Int    @default(0) // effectifs payés
  payrollVsRevenuePercent Float  @default(0) // masse / CA

  // ── 7) Fiscal & réglementaire ─────────────────────────────────────
  vatCollectedXAF          BigInt  @default(0) // TVA collectée
  vatDeductibleXAF         BigInt  @default(0) // TVA déductible
  vatDueXAF                BigInt  @default(0) // solde à payer
  corporateTaxProvisionXAF BigInt  @default(0) // IS provisionné
  socialChargesUpToDate    Boolean @default(true) // CNPS/IRPP à jour
  fiscalDeadlinesNext30d   Int     @default(0) // nombre d'échéances ≤ 30j

  // Sections narratives
  executiveSummary    String? @db.Text // synthèse direction
  performanceAnalysis String? @db.Text // analyse P&L
  cashFlowAnalysis    String? @db.Text // analyse trésorerie
  receivablesAnalysis String? @db.Text // analyse créances / recouvrement
  payablesAnalysis    String? @db.Text // analyse fournisseurs / dettes
  fiscalAnalysis      String? @db.Text // fiscal / réglementaire
  financialRisks      String? @db.Text // risques financiers identifiés
  financialDecisions  String? @db.Text // décisions financières du mois
  recommendations     String? @db.Text // recommandations / arbitrages COMEX
  nextMonthOutlook    String? @db.Text // prévisions mois suivant

  // Workflow
  submittedAt     DateTime?
  validatedById   String?
  validatedBy     User?     @relation("DafMonthlyFinancialReportValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt     DateTime?
  rejectionReason String?   @db.Text

  pdfUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, period])
  @@index([authorId, status])
  @@index([validatedById])
  @@map("daf_monthly_financial_reports")
}

enum DafMonthlyFinancialReportStatus {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
}

// ========================================
// EMP — Demandes de modification de profil
// L'employé édite SON profil via /employe/profil et envoie une demande
// de modification. L'IT (TENANT_ADMIN) valide ou refuse depuis
// /informatique/change-requests.
// ========================================

model ProfileChangeRequest {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation("ChangeRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  // Champs demandés (JSON {field, currentValue, requestedValue}[])
  changes Json
  reason  String? @db.Text

  status        ProfileChangeRequestStatus @default(PENDING)
  reviewedBy    String?
  reviewer      User?                      @relation("ChangeRequestReviewer", fields: [reviewedBy], references: [id])
  reviewedAt    DateTime?
  reviewComment String?                    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, createdAt])
  @@index([userId, status])
  @@map("profile_change_requests")
}

enum ProfileChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────
// Écritures comptables récurrentes (loyers, abonnements, provisions…).
// Stocke un modèle d'écriture (journal + lignes équilibrées) à rejouer
// mensuellement. Pas de FK Prisma sur tenantId/createdById pour éviter
// d'éditer les modèles Tenant/User (filtrage applicatif suffisant).
// ─────────────────────────────────────────────────────────────────────────
model RecurringEntry {
  id            String    @id @default(cuid())
  tenantId      String
  label         String // "Loyer bureau Yaoundé", "Abonnement ENEO"
  journalCode   String // "OD", "ACH"...
  description   String // libellé qui sera repris sur l'écriture générée
  lines         Json      @default("[]") // [{accountCode, debit, credit, thirdPartyId?, description?, siteId?}]
  active        Boolean   @default(true)
  dayOfMonth    Int? // jour préféré du mois (1-28), purement indicatif pour l'UI
  lastRunAt     DateTime?
  lastRunPeriod String? // "YYYY-MM" du dernier run, anti-doublon
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, active])
  @@map("recurring_entries")
}
